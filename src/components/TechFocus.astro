---
// TechFocus.astro
import { resolveLang, useTranslations } from "../i18n/utils";

const lang = resolveLang(Astro.currentLocale);
const t = useTranslations(lang);
---

<section id="tech-focus" class="relative py-32 transition-colors duration-300">
  <div class="container mx-auto max-w-container-max px-margin-mobile">
    <div class="grid grid-cols-1 items-center gap-24 lg:grid-cols-2">
      <!-- Image Column -->
      <div class="relative order-2 lg:order-1">
        <div class="absolute -inset-4 rounded-full bg-primary-container/10 blur-3xl"></div>
        <img
          alt="Radar Analytics Suite UI"
          class="relative z-10 w-full rounded-lg border border-primary/20 shadow-2xl"
          src="/assets/img/example.webp"
        />
        <div
          class="pointer-events-none absolute top-1/2 left-1/2 h-full w-full -translate-x-1/2 -translate-y-1/2 scale-110 rounded-lg border border-primary-container/20"
        >
        </div>
      </div>

      <!-- Text Details Column -->
      <div class="order-1 space-y-8 lg:order-2">
        <h2 class="text-headline-md-mobile font-headline-md text-on-background">
          {t("tech.title")}
        </h2>

        <div class="space-y-6 text-on-surface-variant">
          <p>
            {t("tech.body")}
          </p>

          <ul class="space-y-4 font-technical-label text-sm">
            <li class="flex items-start gap-3">
              <span class="material-symbols-outlined mt-1 text-primary-container">check_circle</span
              >
              <span>
                {t("tech.item1")}
              </span>
            </li>
            <li class="flex items-start gap-3">
              <span class="material-symbols-outlined mt-1 text-primary-container">check_circle</span
              >
              <span>
                {t("tech.item2")}
              </span>
            </li>
            <li class="flex items-start gap-3">
              <span class="material-symbols-outlined mt-1 text-primary-container">check_circle</span
              >
              <span>
                {t("tech.item3")}
              </span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
