---
// CoreTriad.astro
import { resolveLang, useTranslations } from "../i18n/utils";

const lang = resolveLang(Astro.currentLocale);
const t = useTranslations(lang);
---

<section id="hardware" class="relative py-32 transition-colors duration-300">
  <div class="container mx-auto max-w-container-max px-margin-mobile">
    <div class="grid grid-cols-1 gap-gutter md:grid-cols-3">
      <!-- Hardware Card -->
      <div
        class="glass-panel group relative flex flex-col gap-6 overflow-hidden p-10 transition-colors hover:border-primary-container/40"
      >
        <div class="scan-line"></div>
        <div class="flex items-start justify-between">
          <span
            class="material-symbols-outlined text-4xl text-primary-container"
            data-icon="settings_input_antenna">settings_input_antenna</span
          >
          <span class="font-technical-label text-xs text-outline">SRL-01</span>
        </div>
        <h3 class="text-headline-md-mobile font-headline-md text-on-background">
          {t("triad.hw.title")}
        </h3>
        <p class="text-body-sm text-on-surface-variant">
          {t("triad.hw.body")}
        </p>
        <a
          class="mt-auto flex items-center gap-2 font-technical-label text-xs text-primary-container transition-all group-hover:gap-4"
          href="#tech-focus"
        >
          {t("triad.hw.cta")}
          <span class="material-symbols-outlined text-sm">arrow_forward</span>
        </a>
      </div>

      <!-- Software Card -->
      <div
        id="software"
        class="glass-panel group relative flex flex-col gap-6 overflow-hidden p-10 transition-colors hover:border-primary-container/40"
      >
        <div class="scan-line" style="animation-delay: 2s;"></div>
        <div class="flex items-start justify-between">
          <span
            class="material-symbols-outlined text-4xl text-primary-container"
            data-icon="terminal">terminal</span
          >
          <span class="font-technical-label text-xs text-outline">API-v4.2</span>
        </div>
        <h3 class="text-headline-md-mobile font-headline-md text-on-background">
          {t("triad.sw.title")}
        </h3>
        <p class="text-body-sm text-on-surface-variant">
          {t("triad.sw.body")}
        </p>
        <a
          class="mt-auto flex items-center gap-2 font-technical-label text-xs text-primary-container transition-all group-hover:gap-4"
          href="#tech-focus"
        >
          {t("triad.sw.cta")}
          <span class="material-symbols-outlined text-sm">arrow_forward</span>
        </a>
      </div>

      <!-- R&D Card -->
      <div
        id="rd"
        class="glass-panel group relative flex flex-col gap-6 overflow-hidden p-10 transition-colors hover:border-primary-container/40"
      >
        <div class="scan-line" style="animation-delay: 4s;"></div>
        <div class="flex items-start justify-between">
          <span
            class="material-symbols-outlined text-4xl text-primary-container"
            data-icon="science">science</span
          >
          <span class="font-technical-label text-xs text-outline">LAB-7</span>
        </div>
        <h3 class="text-headline-md-mobile font-headline-md text-on-background">
          {t("triad.rd.title")}
        </h3>
        <p class="text-body-sm text-on-surface-variant">
          {t("triad.rd.body")}
        </p>
        <a
          class="mt-auto flex items-center gap-2 font-technical-label text-xs text-primary-container transition-all group-hover:gap-4"
          href="#contact"
        >
          {t("triad.rd.cta")}
          <span class="material-symbols-outlined text-sm">arrow_forward</span>
        </a>
      </div>
    </div>
  </div>
</section>
