---
// CoreTriad.astro
const locale = Astro.currentLocale || 'en';
---
<section id="hardware" class="py-32 relative transition-colors duration-300">
  <div class="container mx-auto px-margin-mobile max-w-container-max">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-gutter">
      <!-- Hardware Card -->
      <div class="glass-panel p-10 flex flex-col gap-6 group hover:border-primary-container/40 transition-colors relative overflow-hidden">
        <div class="scan-line"></div>
        <div class="flex justify-between items-start">
          <span class="material-symbols-outlined text-4xl text-primary-container" data-icon="settings_input_antenna">settings_input_antenna</span>
          <span class="font-technical-label text-xs text-outline">SRL-01</span>
        </div>
        <h3 class="font-headline-md text-headline-md-mobile text-on-background">
          {locale === 'es' ? 'Hardware e Integración' : 'Hardware & Integration'}
        </h3>
        <p class="text-body-sm text-on-surface-variant">
          {locale === 'es' 
            ? 'Arreglos de antenas y módulos transceptores de ingeniería de precisión diseñados para una confiabilidad extrema en los entornos meteorológicos más severos.' 
            : 'Precision-engineered antenna arrays and transceiver modules designed for extreme reliability in harshest meteorological environments.'}
        </p>
        <a class="mt-auto font-technical-label text-xs text-primary-container flex items-center gap-2 group-hover:gap-4 transition-all" href="#tech-focus">
          {locale === 'es' ? 'ESPECIFICACIONES' : 'SPECIFICATIONS'}
          <span class="material-symbols-outlined text-sm">arrow_forward</span>
        </a>
      </div>

      <!-- Software Card -->
      <div id="software" class="glass-panel p-10 flex flex-col gap-6 group hover:border-primary-container/40 transition-colors relative overflow-hidden">
        <div class="scan-line" style="animation-delay: 2s;"></div>
        <div class="flex justify-between items-start">
          <span class="material-symbols-outlined text-4xl text-primary-container" data-icon="terminal">terminal</span>
          <span class="font-technical-label text-xs text-outline">API-v4.2</span>
        </div>
        <h3 class="font-headline-md text-headline-md-mobile text-on-background">
          {locale === 'es' ? 'Procesamiento de Señal y Software' : 'Signal Processing & Software'}
        </h3>
        <p class="text-body-sm text-on-surface-variant">
          {locale === 'es' 
            ? 'Algoritmos propietarios para supresión de eco parásito, calibración de polarización dual y renderizado volumétrico en tiempo real con latencia de subsegundo.' 
            : 'Proprietary algorithms for clutter suppression, dual-polarization calibration, and real-time volumetric rendering at sub-second latency.'}
        </p>
        <a class="mt-auto font-technical-label text-xs text-primary-container flex items-center gap-2 group-hover:gap-4 transition-all" href="#tech-focus">
          {locale === 'es' ? 'DOCS DE DESARROLLADOR' : 'DEVELOPER DOCS'}
          <span class="material-symbols-outlined text-sm">arrow_forward</span>
        </a>
      </div>

      <!-- R&D Card -->
      <div id="rd" class="glass-panel p-10 flex flex-col gap-6 group hover:border-primary-container/40 transition-colors relative overflow-hidden">
        <div class="scan-line" style="animation-delay: 4s;"></div>
        <div class="flex justify-between items-start">
          <span class="material-symbols-outlined text-4xl text-primary-container" data-icon="science">science</span>
          <span class="font-technical-label text-xs text-outline">LAB-7</span>
        </div>
        <h3 class="font-headline-md text-headline-md-mobile text-on-background">
          {locale === 'es' ? 'Consultoría de I+D de Élite' : 'Elite R&D Consulting'}
        </h3>
        <p class="text-body-sm text-on-surface-variant">
          {locale === 'es' 
            ? 'Diseño de arquitectura de sistemas a medida y optimización del rendimiento para instituciones de defensa, aviación e investigación académica.' 
            : 'Bespoke system architecture design and performance optimization for defense, aviation, and academic research institutions.'}
        </p>
        <a class="mt-auto font-technical-label text-xs text-primary-container flex items-center gap-2 group-hover:gap-4 transition-all" href="#contact">
          {locale === 'es' ? 'INICIAR PROYECTO' : 'INITIATE PROJECT'}
          <span class="material-symbols-outlined text-sm">arrow_forward</span>
        </a>
      </div>
    </div>
  </div>
</section>
