---
// Contact.astro
import { resolveLang, useTranslations } from "../i18n/utils";

const lang = resolveLang(Astro.currentLocale);
const t = useTranslations(lang);
---

<section id="contact" class="py-32 transition-colors duration-300">
  <div class="container mx-auto max-w-container-max px-margin-mobile">
    <div
      class="glass-panel flex flex-col items-center gap-16 border-t-2 border-primary-container p-12 md:flex-row md:p-24"
    >
      <!-- Title Column -->
      <div class="flex-1 space-y-6 text-center md:text-left">
        <h2
          class="font-display-lg text-display-lg-mobile leading-tight text-on-background md:text-headline-md"
        >
          {t("contact.title")}
        </h2>
        <p class="text-body-lg text-on-surface-variant">
          {t("contact.body")}
        </p>
      </div>

      <!-- Form Column -->
      <div class="w-full max-w-md">
        <form id="contact-form" class="space-y-6" data-alert={t("contact.alert")}>
          <div class="space-y-2">
            <label class="font-technical-label text-[10px] text-outline uppercase">
              {t("contact.intent.label")}
            </label>
            <select
              class="w-full border border-primary/20 bg-background p-4 font-technical-label text-on-background transition-all duration-300 outline-none focus:border-primary-container"
            >
              <option value="acquisition">{t("contact.intent.acquisition")}</option>
              <option value="consultation">{t("contact.intent.consultation")}</option>
              <option value="licensing">{t("contact.intent.licensing")}</option>
              <option value="maintenance">{t("contact.intent.maintenance")}</option>
            </select>
          </div>

          <div class="space-y-2">
            <label class="font-technical-label text-[10px] text-outline uppercase">
              {t("contact.email.label")}
            </label>
            <input
              class="w-full border border-primary/20 bg-background p-4 font-technical-label text-on-background transition-all duration-300 outline-none placeholder:text-outline/40 focus:border-primary-container"
              placeholder="terminal@agency.gov"
              type="email"
              required
            />
          </div>

          <button
            class="glow-button w-full bg-primary-container py-5 font-technical-label font-bold tracking-widest text-background uppercase transition-all duration-300"
          >
            {t("contact.submit")}
          </button>

          <p class="text-center font-technical-label text-[10px] text-outline opacity-60">
            {t("contact.privacy")}
          </p>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById("contact-form");
  // TODO
  form?.addEventListener("submit", (event) => {
    event.preventDefault();
    alert(form.getAttribute("data-alert"));
  });
</script>
