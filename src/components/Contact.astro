---
// Contact.astro
const locale = Astro.currentLocale || 'en';
---
<section id="contact" class="py-32 transition-colors duration-300">
  <div class="container mx-auto px-margin-mobile max-w-container-max">
    <div class="glass-panel border-t-2 border-primary-container p-12 md:p-24 flex flex-col md:flex-row gap-16 items-center">
      <!-- Title Column -->
      <div class="flex-1 space-y-6 text-center md:text-left">
        <h2 class="font-display-lg text-display-lg-mobile md:text-headline-md text-on-background leading-tight">
          {locale === 'es' ? '¿Listo para elevar sus capacidades de radar?' : 'Ready to elevate your radar capabilities?'}
        </h2>
        <p class="text-body-lg text-on-surface-variant">
          {locale === 'es' 
            ? 'Conéctese directamente con nuestro líder de ingeniería para discutir las especificaciones del sistema, los requisitos de integración o los estudios de viabilidad de I+D.' 
            : 'Connect directly with our engineering lead to discuss system specifications, integration requirements, or R&D feasibility studies.'}
        </p>
      </div>

      <!-- Form Column -->
      <div class="w-full max-w-md">
        <form class="space-y-6" onsubmit="event.preventDefault(); alert(this.getAttribute('data-alert'));" data-alert={locale === 'es' ? 'Consulta técnica iniciada.' : 'Technical consultation initiated.'}>
          <div class="space-y-2">
            <label class="font-technical-label text-[10px] text-outline uppercase">
              {locale === 'es' ? 'Intención del Servicio' : 'Service Intent'}
            </label>
            <select class="w-full bg-background border border-primary/20 p-4 focus:border-primary-container outline-none font-technical-label text-on-background transition-all duration-300">
              <option value="acquisition">{locale === 'es' ? 'Adquisición de Sistemas' : 'System Acquisition'}</option>
              <option value="consultation">{locale === 'es' ? 'Consulta Técnica' : 'Technical Consultation'}</option>
              <option value="licensing">{locale === 'es' ? 'Licencia de Software' : 'Software Licensing'}</option>
              <option value="maintenance">{locale === 'es' ? 'Protocolo de Mantenimiento' : 'Maintenance Protocol'}</option>
            </select>
          </div>

          <div class="space-y-2">
            <label class="font-technical-label text-[10px] text-outline uppercase">
              {locale === 'es' ? 'Hash de Comunicación Seguro (Email)' : 'Secure Communication Hash (Email)'}
            </label>
            <input
              class="w-full bg-background border border-primary/20 p-4 focus:border-primary-container outline-none font-technical-label text-on-background placeholder:text-outline/40 transition-all duration-300"
              placeholder="terminal@agency.gov"
              type="email"
              required
            />
          </div>

          <button class="w-full bg-primary-container text-background font-technical-label py-5 glow-button uppercase tracking-widest font-bold transition-all duration-300">
            {locale === 'es' ? 'Iniciar Consulta Técnica' : 'Initiate Technical Consultation'}
          </button>

          <p class="text-[10px] font-technical-label text-outline text-center opacity-60">
            {locale === 'es' ? 'Todas las consultas se procesan a través de canales de ingeniería seguros.' : 'All inquiries are processed via secure engineering channels.'}
          </p>
        </form>
      </div>
    </div>
  </div>
</section>
