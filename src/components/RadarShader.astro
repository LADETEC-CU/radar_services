---
// RadarShader.astro — full-bleed WebGL radar-sweep background for the hero.
// Theme-aware: the palette follows the active theme via a `u_dark` uniform,
// updated on load and whenever the `.dark` class on <html> toggles.
---

<div class="pointer-events-none absolute inset-0 z-0 h-full w-full">
  <canvas id="radar-shader" class="block h-full w-full opacity-90"></canvas>
</div>

<script>
  (function () {
    const canvas = document.getElementById("radar-shader") as HTMLCanvasElement;
    if (!canvas) return;

    function syncSize() {
      const w = canvas.clientWidth || 1280;
      const h = canvas.clientHeight || 720;
      if (canvas.width !== w || canvas.height !== h) {
        canvas.width = w;
        canvas.height = h;
      }
    }
    if (typeof ResizeObserver !== "undefined") {
      new ResizeObserver(syncSize).observe(canvas);
    }
    syncSize();

    const gl = (canvas.getContext("webgl") ||
      canvas.getContext("experimental-webgl")) as WebGLRenderingContext;
    if (!gl) return;

    const vs = `attribute vec2 a_position;
varying vec2 v_texCoord;
void main() {
  v_texCoord = a_position * 0.5 + 0.5;
  gl_Position = vec4(a_position, 0.0, 1.0);
}`;

    const fs = `precision highp float;
uniform float u_time;
uniform vec2 u_resolution;
uniform float u_dark; // 1.0 dark, 0.0 light
varying vec2 v_texCoord;

// Simplex 2D noise
vec3 permute(vec3 x) { return mod(((x*34.0)+1.0)*x, 289.0); }
float snoise(vec2 v){
  const vec4 C = vec4(0.211324865405187, 0.366025403784439,
           -0.577350269189626, 0.024390243902439);
  vec2 i  = floor(v + dot(v, C.yy) );
  vec2 x0 = v -   i + dot(i, C.xx);
  vec2 i1;
  i1 = (x0.x > x0.y) ? vec2(1.0, 0.0) : vec2(0.0, 1.0);
  vec4 x12 = x0.xyxy + C.xxzz;
  x12.xy -= i1;
  i = mod(i, 289.0);
  vec3 p = permute( permute( i.y + vec3(0.0, i1.y, 1.0 ))
  + i.x + vec3(0.0, i1.x, 1.0 ));
  vec3 m = max(0.5 - vec3(dot(x0,x0), dot(x12.xy,x12.xy),
    dot(x12.zw,x12.zw)), 0.0);
  m = m*m ;
  m = m*m ;
  vec3 x = 2.0 * fract(p * C.www) - 1.0;
  vec3 h = abs(x) - 0.5;
  vec3 ox = floor(x + 0.5);
  vec3 a0 = x - ox;
  m *= 1.79284291400159 - 0.85373472095314 * ( a0*a0 + h*h );
  vec3 g;
  g.x  = a0.x  * x0.x  + h.x  * x0.y;
  g.yz = a0.yz * x12.xz + h.yz * x12.yw;
  return 130.0 * dot(m, g);
}

void main() {
    vec2 uv = v_texCoord;
    vec2 centered_uv = (v_texCoord * 2.0 - 1.0) * vec2(u_resolution.x/u_resolution.y, 1.0);

    // Radar sweep effect
    float angle = atan(centered_uv.y, centered_uv.x);
    float dist = length(centered_uv);
    float sweep = fract(angle / 6.28318 - u_time * 0.2);
    sweep = pow(sweep, 4.0);

    // Atmospheric noise
    float n = snoise(uv * 3.0 + u_time * 0.1);
    n += 0.5 * snoise(uv * 6.0 - u_time * 0.2);

    // Grid lines
    vec2 grid = fract(uv * 15.0);
    float gridLine = smoothstep(0.02, 0.0, grid.x) + smoothstep(0.02, 0.0, grid.y);
    gridLine *= 0.15;

    // Theme-aware palette (light values mixed toward dark values by u_dark)
    vec3 base   = mix(vec3(0.957, 0.965, 0.980), vec3(0.043, 0.059, 0.098), u_dark);
    vec3 accent = mix(vec3(0.021, 0.457, 0.553), vec3(0.000, 0.950, 0.990), u_dark);
    vec3 green  = mix(vec3(0.400, 0.690, 0.980), vec3(0.200, 1.000, 0.400), u_dark);
    vec3 gridColor = mix(vec3(0.300, 0.520, 0.870), vec3(0.5, 0.7, 1.0), u_dark);

    // Composition
    vec3 color = base;

    // Atmospheric volume (storm cells)
    float cell = smoothstep(0.4, 0.8, n);
    color = mix(color, accent * mix(0.50, 0.40, u_dark), cell * (1.0 - dist * 0.5));
    color = mix(color, green * mix(0.50, 0.30, u_dark), cell * sweep);

    // Radar sweep line
    color += accent * sweep * smoothstep(0.8, 0.0, dist) * mix(0.55, 1.0, u_dark);

    // Grid
    color += gridColor * gridLine;

    // Vignette (subtle in light, strong in dark)
    color *= 1.0 - smoothstep(0.5, 1.5, dist) * mix(0.2, 1.0, u_dark);

    gl_FragColor = vec4(color, 1.0);
}`;

    function cs(type: number, src: string) {
      const s = gl.createShader(type);
      if (!s) return null;
      gl.shaderSource(s, src);
      gl.compileShader(s);
      return s;
    }
    const prog = gl.createProgram();
    const vsShader = cs(gl.VERTEX_SHADER, vs);
    const fsShader = cs(gl.FRAGMENT_SHADER, fs);
    if (!prog || !vsShader || !fsShader) return;
    gl.attachShader(prog, vsShader);
    gl.attachShader(prog, fsShader);
    gl.linkProgram(prog);
    gl.useProgram(prog);

    const buf = gl.createBuffer();
    gl.bindBuffer(gl.ARRAY_BUFFER, buf);
    gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1, -1, 1, -1, -1, 1, 1, 1]), gl.STATIC_DRAW);
    const pos = gl.getAttribLocation(prog, "a_position");
    gl.enableVertexAttribArray(pos);
    gl.vertexAttribPointer(pos, 2, gl.FLOAT, false, 0, 0);

    const uTime = gl.getUniformLocation(prog, "u_time");
    const uRes = gl.getUniformLocation(prog, "u_resolution");
    const uDark = gl.getUniformLocation(prog, "u_dark");

    // Follow the active theme (set by the header toggle / flash-prevention script).
    const root = document.documentElement;
    let isDark = root.classList.contains("dark");
    new MutationObserver(() => {
      isDark = root.classList.contains("dark");
    }).observe(root, { attributes: true, attributeFilter: ["class"] });

    function render(t: number) {
      if (typeof ResizeObserver === "undefined") syncSize();
      gl.viewport(0, 0, canvas.width, canvas.height);
      if (uTime) gl.uniform1f(uTime, t * 0.001);
      if (uRes) gl.uniform2f(uRes, canvas.width, canvas.height);
      if (uDark) gl.uniform1f(uDark, isDark ? 1.0 : 0.0);
      gl.drawArrays(gl.TRIANGLE_STRIP, 0, 4);
      requestAnimationFrame(render);
    }
    render(0);
  })();
</script>
