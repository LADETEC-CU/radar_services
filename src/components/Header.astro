---
// Header.astro
import { getRelativeLocaleUrl } from "astro:i18n";
import { resolveLang, useTranslations, otherLang, getRouteFromPathname } from "../i18n/utils";
import { localeCode } from "../i18n/ui";

const lang = resolveLang(Astro.currentLocale);
const t = useTranslations(lang);

const target = otherLang(lang);
const switchHref = getRelativeLocaleUrl(target, getRouteFromPathname(Astro.url.pathname, lang));
---

<header
  class="fixed top-0 z-50 w-full border-b border-primary/10 bg-background/80 shadow-[0px_0px_20px_rgba(0,242,254,0.1)] backdrop-blur-xl transition-colors duration-300"
>
  <div
    class="mx-auto flex h-16 w-full max-w-container-max items-center justify-between px-margin-mobile"
  >
    <!-- Logo & Title (anchors the hero / scrolls to top) -->
    <a href="#hero" aria-label="LADETEC" class="flex items-center gap-3">
      <img alt="LADETEC" class="h-8 w-auto" src="/logo.webp" />
      <span
        class="font-technical-label text-technical-label tracking-widest text-outline uppercase"
      >
        LADETEC SYSTEMS
      </span>
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden items-center gap-8 md:flex">
      <a
        href="#hardware"
        class="font-technical-label text-technical-label text-outline uppercase transition-colors hover:text-primary-container"
      >
        {t("nav.hardware")}
      </a>
      <a
        href="#software"
        class="font-technical-label text-technical-label text-outline uppercase transition-colors hover:text-primary-container"
      >
        {t("nav.software")}
      </a>
      <a
        href="#rd"
        class="font-technical-label text-technical-label text-outline uppercase transition-colors hover:text-primary-container"
      >
        {t("nav.rd")}
      </a>
      <a
        href="#contact"
        class="font-technical-label text-technical-label text-outline uppercase transition-colors hover:text-primary-container"
      >
        {t("nav.contact")}
      </a>
    </nav>

    <!-- Control Group -->
    <div class="flex items-center gap-4">
      <!-- Theme Toggle -->
      <button
        id="theme-toggle"
        class="flex cursor-pointer items-center justify-center p-2 text-outline transition-colors hover:text-primary-container"
        aria-label="Toggle Theme"
      >
        <!-- Moon in light mode, sun in dark mode. Visibility toggled in global.css
             (.dark wins by specificity) so exactly one is ever shown. -->
        <span class="material-symbols-outlined theme-icon-moon text-xl">dark_mode</span>
        <span class="material-symbols-outlined theme-icon-sun text-xl">light_mode</span>
      </button>

      <!-- Language Switcher Link -->
      <a
        id="lang-toggle"
        href={switchHref}
        hreflang={target}
        aria-label={t("nav.switchLabel")}
        class="border border-outline/25 px-3 py-1 font-technical-label text-technical-label font-bold text-outline uppercase transition-colors hover:text-primary-container"
      >
        {localeCode[target]}
      </a>

      <!-- Mobile Menu Toggle -->
      <button
        id="menu-toggle"
        class="flex cursor-pointer items-center justify-center p-2 text-outline transition-colors hover:text-primary-container md:hidden"
        aria-label="Toggle Menu"
      >
        <span class="material-symbols-outlined text-xl">menu</span>
      </button>
    </div>
  </div>

  <!-- Mobile Drawer -->
  <div
    id="mobile-drawer"
    class="flex hidden flex-col gap-4 border-t border-primary/10 bg-background/95 px-margin-mobile py-6 backdrop-blur-xl md:hidden"
  >
    <a
      href="#hardware"
      class="border-b border-primary/5 py-2 font-technical-label text-technical-label text-on-surface-variant uppercase hover:text-on-surface"
    >
      {t("nav.hardware")}
    </a>
    <a
      href="#software"
      class="border-b border-primary/5 py-2 font-technical-label text-technical-label text-on-surface-variant uppercase hover:text-on-surface"
    >
      {t("nav.software")}
    </a>
    <a
      href="#rd"
      class="border-b border-primary/5 py-2 font-technical-label text-technical-label text-on-surface-variant uppercase hover:text-on-surface"
    >
      {t("nav.rd")}
    </a>
    <a
      href="#contact"
      class="py-2 font-technical-label text-technical-label text-on-surface-variant uppercase hover:text-on-surface"
    >
      {t("nav.contact")}
    </a>
  </div>
</header>

<script>
  // Theme Toggler Logic
  const themeToggle = document.getElementById("theme-toggle");
  if (themeToggle) {
    themeToggle.addEventListener("click", () => {
      const isDark = document.documentElement.classList.contains("dark");
      if (isDark) {
        document.documentElement.classList.remove("dark");
        localStorage.setItem("theme", "light");
      } else {
        document.documentElement.classList.add("dark");
        localStorage.setItem("theme", "dark");
      }
    });
  }

  // Mobile Menu Drawer Logic
  const menuToggle = document.getElementById("menu-toggle");
  const mobileDrawer = document.getElementById("mobile-drawer");
  if (menuToggle && mobileDrawer) {
    menuToggle.addEventListener("click", () => {
      mobileDrawer.classList.toggle("hidden");
    });
  }

  // Language Switch — keep the switcher pointed at the section currently in view,
  // so changing locale lands you in the same place instead of scrolling to the top.
  // switchHref is built server-side (no URL fragment available there); a scroll-spy
  // appends the active section's #id in the browser. Tracking is driven by whatever
  // the in-page nav links to, so the same anchors exist on both locale routes.
  const langToggle = document.getElementById("lang-toggle");
  if (langToggle) {
    const baseHref = langToggle.getAttribute("href") ?? "";
    const anchorIds = new Set(
      [...document.querySelectorAll('a[href^="#"]')].map((a) =>
        (a.getAttribute("href") ?? "").slice(1)
      )
    );
    const visible = new Map(); // id -> intersection ratio
    const apply = () => {
      let activeId = "";
      let best = 0;
      for (const [id, ratio] of visible) {
        if (ratio > best) {
          best = ratio;
          activeId = id;
        }
      }
      langToggle.setAttribute("href", baseHref + (activeId ? "#" + activeId : ""));
    };
    const spy = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) visible.set(e.target.id, e.intersectionRatio);
          else visible.delete(e.target.id);
        }
        apply();
      },
      { threshold: [0, 0.25, 0.5, 0.75, 1] }
    );
    document.querySelectorAll("main [id]").forEach((el) => {
      if (anchorIds.has(el.id)) spy.observe(el);
    });
    // The footer lives outside <main>; track it too so switching locale from
    // the footer keeps you on the footer instead of jumping to a section.
    const footerEl = document.querySelector("footer[id]");
    if (footerEl) spy.observe(footerEl);
  }
</script>
