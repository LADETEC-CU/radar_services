---
// Header.astro
const locale = Astro.currentLocale || 'en';
---
<header class="fixed top-0 w-full z-50 bg-background/80 backdrop-blur-xl border-b border-primary/10 shadow-[0px_0px_20px_rgba(0,242,254,0.1)] transition-colors duration-300">
  <div class="flex justify-between items-center px-margin-mobile h-16 w-full max-w-container-max mx-auto">
    <!-- Logo & Title -->
    <div class="flex items-center gap-3">
      <img
        alt="LADETEC"
        class="h-8 w-auto dark:grayscale-0 grayscale transition-all duration-300"
        src="data:image/png;base64, holidays, etc.)"
      />
      <span class="font-technical-label text-technical-label text-outline uppercase tracking-widest">
        LADETEC SYSTEMS
      </span>
    </div>

    <!-- Desktop Navigation -->
    <nav class="hidden md:flex items-center gap-8">
      <a href="#hardware" class="font-technical-label text-technical-label text-outline hover:text-primary-container transition-colors uppercase">
        {locale === 'es' ? 'Hardware' : 'Hardware'}
      </a>
      <a href="#software" class="font-technical-label text-technical-label text-outline hover:text-primary-container transition-colors uppercase">
        {locale === 'es' ? 'Software' : 'Software'}
      </a>
      <a href="#rd" class="font-technical-label text-technical-label text-outline hover:text-primary-container transition-colors uppercase">
        {locale === 'es' ? 'I+D' : 'R&D'}
      </a>
      <a href="#contact" class="font-technical-label text-technical-label text-outline hover:text-primary-container transition-colors uppercase">
        {locale === 'es' ? 'Consulta' : 'Consultation'}
      </a>
    </nav>

    <!-- Control Group -->
    <div class="flex items-center gap-4">
      <!-- Theme Toggle -->
      <button
        id="theme-toggle"
        class="p-2 text-outline hover:text-primary-container transition-colors flex items-center justify-center cursor-pointer"
        aria-label="Toggle Theme"
      >
        <span class="material-symbols-outlined text-xl">dark_mode</span>
      </button>
      
      <!-- Language Switcher Link -->
      <a
        id="lang-toggle"
        href={locale === 'es' ? '/' : '/es/'}
        class="font-technical-label text-technical-label text-outline hover:text-primary-container border border-outline/25 px-3 py-1 transition-colors uppercase font-bold"
      >
        {locale === 'es' ? 'EN' : 'ES'}
      </a>
      
      <!-- Mobile Menu Toggle -->
      <button
        id="menu-toggle"
        class="md:hidden p-2 text-outline hover:text-primary-container transition-colors flex items-center justify-center cursor-pointer"
        aria-label="Toggle Menu"
      >
        <span class="material-symbols-outlined text-xl">menu</span>
      </button>
    </div>
  </div>

  <!-- Mobile Drawer -->
  <div id="mobile-drawer" class="hidden md:hidden border-t border-primary/10 bg-background/95 backdrop-blur-xl px-margin-mobile py-6 flex flex-col gap-4">
    <a href="#hardware" class="font-technical-label text-technical-label text-on-surface-variant hover:text-on-surface py-2 border-b border-primary/5">
      {locale === 'es' ? 'HARDWARE' : 'HARDWARE'}
    </a>
    <a href="#software" class="font-technical-label text-technical-label text-on-surface-variant hover:text-on-surface py-2 border-b border-primary/5">
      {locale === 'es' ? 'SOFTWARE' : 'SOFTWARE'}
    </a>
    <a href="#rd" class="font-technical-label text-technical-label text-on-surface-variant hover:text-on-surface py-2 border-b border-primary/5">
      {locale === 'es' ? 'I+D' : 'R&D'}
    </a>
    <a href="#contact" class="font-technical-label text-technical-label text-on-surface-variant hover:text-on-surface py-2">
      {locale === 'es' ? 'CONSULTA' : 'CONSULTATION'}
    </a>
  </div>
</header>

<script>
  // Theme Toggler Logic
  const themeToggle = document.getElementById('theme-toggle');
  if (themeToggle) {
    themeToggle.addEventListener('click', () => {
      const isDark = document.documentElement.classList.contains('dark');
      if (isDark) {
        document.documentElement.classList.remove('dark');
        localStorage.setItem('theme', 'light');
      } else {
        document.documentElement.classList.add('dark');
        localStorage.setItem('theme', 'dark');
      }
    });
  }

  // Mobile Menu Drawer Logic
  const menuToggle = document.getElementById('menu-toggle');
  const mobileDrawer = document.getElementById('mobile-drawer');
  if (menuToggle && mobileDrawer) {
    menuToggle.addEventListener('click', () => {
      mobileDrawer.classList.toggle('hidden');
    });
  }
</script>
