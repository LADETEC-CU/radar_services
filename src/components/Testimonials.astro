---
// Testimonials.astro
import enTestimonials from "../data/testimonials.en.json";
import esTestimonials from "../data/testimonials.es.json";
import "swiper/css";
import "swiper/css/pagination";
import "swiper/css/autoplay";
import { resolveLang, useTranslations } from "../i18n/utils";

const lang = resolveLang(Astro.currentLocale);
const t = useTranslations(lang);

// Quote data is split per locale (data/testimonials.<lang>.json); pick by lang.
const testimonialsByLang = { en: enTestimonials, es: esTestimonials };

const testimonials = testimonialsByLang[lang].map((item) => {
  // Dynamic font size based on body length, bounded between 15px and 22px.
  const fsize = Math.max(15, Math.min(22, Math.round(24 - item.body.length / 27)));
  return { ...item, fsize };
});

function getInitials(name: string) {
  const parts = name.split(" ").filter(Boolean);
  if (parts.length >= 2) {
    return (parts[0][0] + parts[1][0]).toUpperCase();
  }
  return parts[0] ? parts[0][0].toUpperCase() : "";
}
---

<section
  id="testimonials"
  class="relative overflow-hidden bg-surface-container-lowest/30 py-32 transition-colors duration-300"
>
  <!-- Decorative background elements -->
  <div
    class="pointer-events-none absolute top-1/4 left-0 h-96 w-96 rounded-full bg-primary-container/5 blur-[120px]"
  >
  </div>
  <div
    class="pointer-events-none absolute right-0 bottom-1/4 h-96 w-96 rounded-full bg-primary-container/5 blur-[120px]"
  >
  </div>

  <div class="relative z-10 container mx-auto max-w-container-max px-margin-mobile">
    <!-- Section Title -->
    <div class="mx-auto mb-20 max-w-3xl space-y-4 text-center">
      <div class="inline-block border-b border-primary-container/20 pb-2">
        <h2
          class="font-technical-label text-sm font-bold tracking-widest text-primary-container uppercase"
        >
          {t("testimonials.eyebrow")}
        </h2>
      </div>
      <p class="mx-auto max-w-2xl text-body-lg text-on-surface-variant">
        {t("testimonials.intro")}
      </p>
    </div>

    <!-- Swiper Container -->
    <swiper-container
      init="false"
      class="testimonials-swiper pb-20"
      speed="600"
      rewind="true"
      autoplay-delay="8000"
      autoplay-disable-on-interaction="false"
      pagination="true"
      pagination-clickable="true"
    >
      {
        testimonials.map((item) => (
          <swiper-slide class="h-auto">
            <div class="testimonial-wrap h-full p-1">
              <div class="glass-panel group relative flex h-full flex-col justify-between overflow-hidden rounded-xl bg-surface/5 p-8 shadow-lg transition-all duration-300 hover:border-primary-container/40 dark:bg-surface-container-lowest/10">
                {/* Decorative Quote Mark */}
                <span class="pointer-events-none absolute -top-2 right-4 pt-[0.1em] font-serif text-8xl text-primary-container/10 transition-colors duration-300 select-none group-hover:text-primary-container/20">
                  ”
                </span>

                {/* Quote Content */}
                <div class="mb-8 flex-1">
                  <p
                    class="font-sans leading-relaxed font-medium text-on-background/90 italic"
                    style={`font-size: ${item.fsize}px;`}
                  >
                    "{item.body}"
                  </p>
                </div>

                {/* Author Metadata */}
                <div class="flex items-center gap-4 border-t border-primary/10 pt-6">
                  {/* Avatar with Initials Fallback */}
                  <div class="relative flex h-14 w-14 flex-shrink-0 items-center justify-center overflow-hidden rounded-full border-2 border-primary-container/30 bg-gradient-to-br from-primary-container/20 to-primary-container/5 shadow-md">
                    <img
                      src={item.image}
                      alt={item.name}
                      class="absolute inset-0 h-full w-full object-cover transition-opacity duration-300"
                      loading="lazy"
                      onerror="this.style.opacity='0';"
                    />
                    <span class="font-technical-label text-sm font-bold text-primary-container uppercase select-none">
                      {getInitials(item.name)}
                    </span>
                  </div>

                  {/* Name & Position */}
                  <div class="min-w-0">
                    <h3 class="truncate font-sans text-base font-bold text-on-background">
                      {item.name}
                    </h3>
                    <p
                      class="mt-1 truncate font-technical-label text-[10px] tracking-wider text-outline uppercase"
                      title={item.position}
                    >
                      {item.position}
                    </p>
                  </div>
                </div>
              </div>
            </div>
          </swiper-slide>
        ))
      }
    </swiper-container>
  </div>
</section>

<style>
  swiper-container {
    --swiper-pagination-color: var(--color-primary-container);
    --swiper-pagination-bullet-inactive-color: var(--color-outline);
    --swiper-pagination-bullet-inactive-opacity: 0.3;
    --swiper-pagination-bullet-size: 8px;
    --swiper-theme-color: var(--color-primary-container);
  }

  /* Give the pagination dots breathing room below the cards. */
  .testimonials-swiper::part(container) {
    padding-bottom: 2.5rem;
  }

  /* Make sure slides take equal height in the grid */
  swiper-slide {
    height: auto !important;
  }
</style>

<script>
  import { register } from "swiper/element/bundle";
  register();

  // Initialize Swiper with custom responsive parameters
  const swiperEl = document.querySelector(".testimonials-swiper");
  if (swiperEl) {
    const params = {
      breakpoints: {
        320: {
          slidesPerView: 1,
          spaceBetween: 20,
        },
        768: {
          slidesPerView: 2,
          spaceBetween: 24,
        },
        1024: {
          slidesPerView: 3,
          spaceBetween: 30,
        },
      },
    };
    Object.assign(swiperEl, params);
    // @ts-expect-error — swiperEl is the swiper-container custom element
    swiperEl.initialize();
  }
</script>
