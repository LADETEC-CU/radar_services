---
// Testimonials.astro
import data from "../data/testimonials.json";
import "swiper/css";
import "swiper/css/pagination";
import "swiper/css/autoplay";

const locale = Astro.currentLocale || 'en';

const testimonials = data.testimonials.map((t) => {
  const body = locale === 'es' ? t.body_es : t.body_en;
  const position = locale === 'es' ? t.position_es : t.position_en;
  // Calculate dynamic font size based on body length, bounded between 15px and 22px
  const fsize = Math.max(15, Math.min(22, Math.round(24 - body.length / 27)));
  
  return {
    name: t.name,
    image: t.image,
    position,
    body,
    fsize
  };
});

function getInitials(name: string) {
  const parts = name.split(' ').filter(Boolean);
  if (parts.length >= 2) {
    return (parts[0][0] + parts[1][0]).toUpperCase();
  }
  return parts[0] ? parts[0][0].toUpperCase() : '';
}
---

<section id="testimonials" class="py-32 bg-surface-container-lowest/30 transition-colors duration-300 relative overflow-hidden">
  <!-- Decorative background elements -->
  <div class="absolute top-1/4 left-0 w-96 h-96 bg-primary-container/5 blur-[120px] rounded-full pointer-events-none"></div>
  <div class="absolute bottom-1/4 right-0 w-96 h-96 bg-secondary/5 blur-[120px] rounded-full pointer-events-none"></div>

  <div class="container mx-auto px-margin-mobile max-w-container-max relative z-10">
    <!-- Section Title -->
    <div class="max-w-3xl mx-auto text-center mb-20 space-y-4">
      <div class="inline-block border-b border-primary-container/20 pb-2">
        <h2 class="font-technical-label text-sm uppercase tracking-widest text-primary-container font-bold">
          {locale === 'es' ? 'Testimonios' : 'Testimonials'}
        </h2>
      </div>
      <p class="text-body-lg text-on-surface-variant max-w-2xl mx-auto">
        {locale === 'es' 
          ? 'Algunas personas con altas responsabilidades han comentado sobre el trabajo de LADETEC en todos estos años. Tenemos además el honor de haber sido la casa y escuela de muchos excelentes ingenieros que hoy trabajan por el mundo.' 
          : 'Key leaders and professionals share their insights on LADETEC’s contributions over the years. We are also honored to have been the home and school of many excellent engineers now working globally.'}
      </p>
    </div>

    <!-- Swiper Container -->
    <swiper-container
      init="false"
      class="testimonials-swiper pb-16"
      speed="600"
      rewind="true"
      autoplay-delay="8000"
      autoplay-disable-on-interaction="false"
      pagination="true"
      pagination-clickable="true"
    >
      {testimonials.map((t) => (
        <swiper-slide class="h-auto">
          <div class="testimonial-wrap p-1 h-full">
            <div class="glass-panel rounded-xl p-8 h-full flex flex-col justify-between hover:border-primary-container/40 transition-all duration-300 shadow-lg relative group overflow-hidden bg-surface/5 dark:bg-surface-container-lowest/10">
              <!-- Decorative Quote Mark -->
              <span class="absolute -top-2 right-4 text-primary-container/10 group-hover:text-primary-container/20 text-8xl font-serif pointer-events-none select-none transition-colors duration-300">”</span>
              
              <!-- Quote Content -->
              <div class="flex-1 mb-8">
                <p 
                  class="italic text-on-background/90 leading-relaxed font-sans font-medium"
                  style={`font-size: ${t.fsize}px;`}
                >
                  "{t.body}"
                </p>
              </div>

              <!-- Author Metadata -->
              <div class="flex items-center gap-4 border-t border-primary/10 pt-6">
                <!-- Avatar with Initials Fallback -->
                <div class="relative w-14 h-14 rounded-full overflow-hidden border-2 border-primary-container/30 shadow-md flex-shrink-0 bg-gradient-to-br from-primary-container/15 to-secondary/15 flex items-center justify-center">
                  <img
                    src={t.image}
                    alt={t.name}
                    class="absolute inset-0 w-full h-full object-cover transition-opacity duration-300"
                    loading="lazy"
                    onerror="this.style.opacity='0';"
                  />
                  <span class="font-technical-label text-sm text-primary-container font-bold uppercase select-none">
                    {getInitials(t.name)}
                  </span>
                </div>
                
                <!-- Name & Position -->
                <div class="min-w-0">
                  <h3 class="font-sans font-bold text-on-background text-base truncate">{t.name}</h3>
                  <p class="font-technical-label text-[10px] text-outline uppercase tracking-wider truncate mt-1" title={t.position}>
                    {t.position}
                  </p>
                </div>
              </div>
            </div>
          </div>
        </swiper-slide>
      ))}
    </swiper-container>
  </div>
</section>

<style>
  swiper-container {
    --swiper-pagination-color: var(--color-primary-container);
    --swiper-pagination-bullet-inactive-color: var(--color-outline);
    --swiper-pagination-bullet-inactive-opacity: 0.3;
    --swiper-pagination-bullet-size: 8px;
    --swiper-theme-color: var(--color-primary-container);
  }
  
  /* Make sure slides take equal height in the grid */
  swiper-slide {
    height: auto !important;
  }
</style>

<script>
  import { register } from 'swiper/element/bundle';
  register();

  // Initialize Swiper with custom responsive parameters
  const swiperEl = document.querySelector('.testimonials-swiper');
  if (swiperEl) {
    const params = {
      breakpoints: {
        320: {
          slidesPerView: 1,
          spaceBetween: 20,
        },
        768: {
          slidesPerView: 2,
          spaceBetween: 24,
        },
        1024: {
          slidesPerView: 3,
          spaceBetween: 30,
        },
      },
    };
    Object.assign(swiperEl, params);
    // @ts-ignore
    swiperEl.initialize();
  }
</script>
