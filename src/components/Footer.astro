---
// Footer.astro
import { resolveLang, useTranslations } from "../i18n/utils";

const lang = resolveLang(Astro.currentLocale);
const t = useTranslations(lang);
---

<footer
  class="border-t border-primary/5 bg-surface-container-lowest py-16 transition-colors duration-300"
>
  <div
    class="container mx-auto flex max-w-container-max flex-col items-center justify-between gap-8 px-margin-mobile text-center md:flex-row md:text-left"
  >
    <a href="#hero" aria-label="LADETEC" class="flex items-center gap-2">
      <img
        alt="LADETEC"
        class="h-6 w-auto grayscale transition-all duration-300 dark:grayscale-0"
        src="/logo.webp"
      />
      <span
        class="font-technical-label text-technical-label tracking-widest text-outline uppercase"
      >
        LADETEC SYSTEMS
      </span>
    </a>

    <nav class="flex flex-wrap justify-center gap-x-12 gap-y-4">
      <a
        href="#hardware"
        class="font-technical-label text-technical-label text-outline transition-colors hover:text-primary-container"
      >
        {t("footer.hardware")}
      </a>
      <a
        href="#software"
        class="font-technical-label text-technical-label text-outline transition-colors hover:text-primary-container"
      >
        {t("footer.software")}
      </a>
      <a
        href="#contact"
        class="font-technical-label text-technical-label text-outline transition-colors hover:text-primary-container"
      >
        {t("footer.privacy")}
      </a>
      <a
        href="#contact"
        class="font-technical-label text-technical-label text-outline transition-colors hover:text-primary-container"
      >
        {t("footer.terminal")}
      </a>
    </nav>

    <div class="space-y-2 opacity-80">
      <p class="font-technical-label text-[10px] tracking-widest text-outline uppercase">
        {t("footer.copyright")}
      </p>
      <p class="font-technical-label text-[10px] text-primary-container/40">
        {t("footer.spec")}
      </p>
    </div>
  </div>
</footer>
