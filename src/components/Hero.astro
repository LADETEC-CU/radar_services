---
import { resolveLang, useTranslations } from "../i18n/utils";
const lang = resolveLang(Astro.currentLocale);
const t = useTranslations(lang);
---

<style is:global>
  @import "leaflet/dist/leaflet.css";

  /* ---- Radar hero: always-dark, theme-isolated ---- */
  .radar-hero {
    --rh-bg: #070b10;
    --rh-text: #e7ecf2;
    --rh-muted: #8a97a6;
    --rh-line: rgba(255, 255, 255, 0.12);
    --rh-panel: rgba(9, 13, 19, 0.55);
    --rh-signal: #35e0c4;

    position: relative;
    width: 100%;
    height: 100svh;
    min-height: 560px;
    overflow: hidden;
    background: var(--rh-bg);
    isolation: isolate;
  }

  .radar-hero #rh-map {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .radar-hero .leaflet-container {
    background: var(--rh-bg);
    font-family: "JetBrains Mono", ui-monospace, monospace;
  }
  .radar-hero .leaflet-control-attribution {
    background: rgba(7, 11, 16, 0.66) !important;
    color: var(--rh-muted) !important;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 10.5px;
    backdrop-filter: blur(4px);
  }
  .radar-hero .leaflet-control-attribution a {
    color: #b9c4d1 !important;
  }

  /* Scrims */
  .rh-scrim {
    position: absolute;
    inset: 0;
    z-index: 400;
    pointer-events: none;
  }
  .rh-scrim::before,
  .rh-scrim::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    height: 34%;
  }
  .rh-scrim::before {
    top: 0;
    background: linear-gradient(to bottom, rgba(7, 11, 16, 0.78), rgba(7, 11, 16, 0));
  }
  .rh-scrim::after {
    bottom: 0;
    background: linear-gradient(to top, rgba(7, 11, 16, 0.86), rgba(7, 11, 16, 0));
  }

  /* HUD layers */
  .rh-hud {
    position: absolute;
    z-index: 1000;
    pointer-events: none;
  }
  .rh-hud--top {
    top: 0;
    left: 0;
    right: 0;
    padding: 22px clamp(18px, 4vw, 44px);
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 18px;
  }
  .rh-hud--bottom {
    bottom: 0;
    left: 0;
    right: 0;
    padding: 0 clamp(18px, 4vw, 44px) 20px;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
  }

  /* Brand / live dot */
  .rh-brand {
    display: flex;
    align-items: center;
    gap: 9px;
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--rh-text);
    font-family: "Inter", ui-sans-serif, system-ui, sans-serif;
  }
  .rh-brand__name {
    color: var(--rh-muted);
  }
  .rh-live-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--rh-signal);
    box-shadow: 0 0 0 0 rgba(53, 224, 196, 0.7);
    animation: rh-pulse 2s ease-out infinite;
  }
  @keyframes rh-pulse {
    0% {
      box-shadow: 0 0 0 0 rgba(53, 224, 196, 0.55);
    }
    70% {
      box-shadow: 0 0 0 10px rgba(53, 224, 196, 0);
    }
    100% {
      box-shadow: 0 0 0 0 rgba(53, 224, 196, 0);
    }
  }

  .rh-place {
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 12.5px;
    color: var(--rh-muted);
    text-align: right;
  }
  .rh-place strong {
    color: var(--rh-text);
    font-weight: 500;
  }

  /* Pitch overlay */
  .rh-pitch {
    position: absolute;
    z-index: 1000;
    pointer-events: none;
    top: clamp(76px, 14vh, 150px);
    left: clamp(18px, 4vw, 44px);
    max-width: min(560px, 80%);
  }
  .rh-pitch h1 {
    margin: 0 0 10px;
    font-family: "Inter", ui-sans-serif, system-ui, sans-serif;
    font-size: clamp(28px, 5vw, 52px);
    line-height: 1.03;
    font-weight: 600;
    letter-spacing: -0.02em;
    text-wrap: balance;
    text-shadow: 0 2px 30px rgba(0, 0, 0, 0.55);
    color: var(--rh-text);
  }
  .rh-pitch h1 .rh-accent {
    color: var(--rh-signal);
  }
  .rh-pitch p {
    margin: 0 0 24px;
    font-family: "Inter", ui-sans-serif, system-ui, sans-serif;
    font-size: clamp(14px, 1.6vw, 17px);
    line-height: 1.5;
    color: #c2ccd7;
    max-width: 44ch;
  }
  .rh-ctas {
    display: flex;
    flex-direction: column;
    gap: 12px;
    pointer-events: all;
  }
  @media (min-width: 480px) {
    .rh-ctas {
      flex-direction: row;
    }
  }

  .rh-cta-primary {
    display: inline-block;
    background: var(--rh-signal);
    color: var(--rh-bg);
    padding: 14px 32px;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 11px;
    letter-spacing: 0.12em;
    font-weight: 700;
    text-transform: uppercase;
    text-decoration: none;
    text-align: center;
    box-shadow: 0 0 0 rgba(53, 224, 196, 0);
    transition:
      box-shadow 0.25s,
      transform 0.25s;
  }
  .rh-cta-primary:hover {
    box-shadow: 0 0 22px rgba(53, 224, 196, 0.55);
    transform: translateY(-2px);
  }
  .rh-cta-secondary {
    display: inline-block;
    border: 1px solid var(--rh-signal);
    color: var(--rh-signal);
    padding: 14px 32px;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    text-align: center;
    transition: background 0.2s;
  }
  .rh-cta-secondary:hover {
    background: rgba(53, 224, 196, 0.1);
  }

  /* Intensity legend */
  .rh-legend {
    pointer-events: none;
  }
  .rh-legend__label {
    font-family: "JetBrains Mono", monospace;
    font-size: 10.5px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--rh-muted);
    margin-bottom: 7px;
  }
  .rh-legend__bar {
    height: 8px;
    width: min(220px, 42vw);
    border-radius: 999px;
    border: 1px solid var(--rh-line);
    background: linear-gradient(
      90deg,
      #0a2a5e 0%,
      #1f6fd0 22%,
      #25c39a 46%,
      #e4d33b 68%,
      #ec7a2a 84%,
      #d63b3b 100%
    );
  }
  .rh-legend__scale {
    display: flex;
    justify-content: space-between;
    margin-top: 6px;
    font-family: "JetBrains Mono", monospace;
    font-size: 10px;
    color: var(--rh-muted);
  }

  /* Timeline */
  .rh-timeline {
    pointer-events: none;
    min-width: min(360px, 90vw);
    flex: 1 1 300px;
    max-width: 520px;
  }
  .rh-timeline__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 8px;
  }
  .rh-timeline__scale {
    font-family: "JetBrains Mono", monospace;
    font-size: 10.5px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--rh-muted);
  }
  .rh-timeline__readout {
    font-family: "JetBrains Mono", monospace;
    font-size: 13px;
    color: var(--rh-text);
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .rh-live-tag {
    font-size: 9.5px;
    letter-spacing: 0.14em;
    padding: 2px 7px;
    border-radius: 999px;
    color: var(--rh-bg);
    background: var(--rh-signal);
    font-weight: 600;
    opacity: 0;
    transition: opacity 0.2s;
  }
  .rh-live-tag.is-on {
    opacity: 1;
  }
  .rh-timeline__track {
    position: relative;
    height: 3px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.14);
  }
  .rh-timeline__fill {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 0%;
    border-radius: 999px;
    background: var(--rh-signal);
    transition: width 0.28s ease;
  }
  .rh-timeline__dot {
    position: absolute;
    top: 50%;
    left: 0%;
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: var(--rh-signal);
    transform: translate(-50%, -50%);
    transition: left 0.28s ease;
    box-shadow: 0 0 12px rgba(53, 224, 196, 0.7);
  }

  /* User location marker */
  .rh-user-pin {
    position: relative;
  }
  .rh-user-pin__core {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 9px;
    height: 9px;
    margin: -4.5px 0 0 -4.5px;
    border-radius: 50%;
    background: var(--rh-signal);
    box-shadow:
      0 0 0 2px rgba(7, 11, 16, 0.9),
      0 0 14px rgba(53, 224, 196, 0.9);
  }
  .rh-user-pin__ring {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 9px;
    height: 9px;
    margin: -4.5px 0 0 -4.5px;
    border-radius: 50%;
    border: 1.5px solid var(--rh-signal);
    animation: rh-ping 2.4s ease-out infinite;
  }
  @keyframes rh-ping {
    0% {
      transform: scale(1);
      opacity: 0.8;
    }
    100% {
      transform: scale(4.2);
      opacity: 0;
    }
  }

  /* Status notice */
  .rh-notice {
    position: absolute;
    z-index: 1001;
    left: 50%;
    bottom: 96px;
    transform: translateX(-50%);
    pointer-events: none;
    padding: 8px 14px;
    border: 1px solid var(--rh-line);
    border-radius: 999px;
    background: var(--rh-panel);
    backdrop-filter: blur(8px);
    font-family: "JetBrains Mono", monospace;
    font-size: 12px;
    color: var(--rh-muted);
    opacity: 0;
    transition: opacity 0.3s;
    white-space: nowrap;
  }
  .rh-notice.is-on {
    opacity: 1;
  }

  @media (max-width: 640px) {
    .rh-place {
      display: none;
    }
    .rh-pitch {
      max-width: 88%;
    }
    .rh-hud--bottom {
      gap: 16px;
    }
    .rh-legend {
      order: 2;
    }
    .rh-timeline {
      order: 1;
      flex-basis: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .rh-live-dot,
    .rh-user-pin__ring {
      animation: none;
    }
    .rh-timeline__fill,
    .rh-timeline__dot {
      transition: none;
    }
  }
</style>

<section id="hero" class="radar-hero" aria-label={t("hero.radar.aria")}>
  <div id="rh-map" role="img" aria-label={t("hero.radar.mapAria")}></div>
  <div class="rh-scrim"></div>

  <!-- Top HUD -->
  <div class="rh-hud rh-hud--top">
    <div class="rh-brand">
      <span class="rh-live-dot"></span>
      {t("hero.radar.live")} &middot; <span class="rh-brand__name">Radar</span>
    </div>
    <div class="rh-place">
      {t("hero.radar.over")}
      <strong id="rvPlace">{t("hero.radar.locating")}</strong>
    </div>
  </div>

  <!-- Pitch -->
  <div class="rh-pitch">
    <h1>
      {t("hero.title.lead")}<br />
      <span class="rh-accent">{t("hero.title.accent")}</span>
    </h1>
    <p set:html={t("hero.lead")} />
    <div class="rh-ctas">
      <a href="#tech-focus" class="rh-cta-primary">{t("hero.cta.primary")}</a>
      <a href="#contact" class="rh-cta-secondary">{t("hero.cta.secondary")}</a>
    </div>
  </div>

  <!-- Bottom HUD -->
  <div class="rh-hud rh-hud--bottom">
    <div class="rh-legend">
      <div class="rh-legend__label">{t("hero.radar.intensity")}</div>
      <div class="rh-legend__bar"></div>
      <div class="rh-legend__scale">
        <span>{t("hero.radar.light")}</span>
        <span>{t("hero.radar.heavy")}</span>
      </div>
    </div>

    <div class="rh-timeline">
      <div class="rh-timeline__head">
        <span class="rh-timeline__scale">{t("hero.radar.scale")}</span>
        <span class="rh-timeline__readout">
          <span id="rvClock">--:--</span>
          <span class="rh-live-tag" id="rvLive">{t("hero.radar.now")}</span>
        </span>
      </div>
      <div class="rh-timeline__track">
        <div class="rh-timeline__fill" id="rvFill"></div>
        <div class="rh-timeline__dot" id="rvDot"></div>
      </div>
    </div>
  </div>

  <div class="rh-notice" id="rvNotice" data-nodata={t("hero.radar.nodata")}></div>
</section>

<script>
  import L from "leaflet";

  interface TimedLayer extends L.TileLayer {
    _time?: number;
  }

  interface GeoResult {
    lat: number;
    lon: number;
    label: string;
  }

  const CFG = {
    ZOOM: 7,
    RADAR_OPACITY: 0.82,
    FRAME_MS: 480,
    PAUSE_LAST_MS: 1500,
    TILE_SIZE: 256,
    COLOR: 2,
    OPTIONS: "1_1",
    FALLBACK: { lat: 39.83, lon: -98.58, label: "—" },
  };

  const $rh = (id: string) => document.getElementById(id) as HTMLElement;
  const pad = (n: number) => String(n).padStart(2, "0");
  const fmtTime = (unix: number) => {
    const d = new Date(unix * 1000);
    return `${pad(d.getHours())}:${pad(d.getMinutes())}`;
  };
  const prefersReduced = window.matchMedia("(prefers-reduced-motion:reduce)").matches;

  function showNotice() {
    const n = $rh("rvNotice") as HTMLDivElement;
    n.textContent = n.dataset.nodata ?? "";
    n.classList.add("is-on");
  }

  const map = L.map("rh-map", {
    zoomControl: false,
    attributionControl: true,
    scrollWheelZoom: false,
    center: [CFG.FALLBACK.lat, CFG.FALLBACK.lon],
    zoom: CFG.ZOOM,
  });
  map.attributionControl.setPrefix(false);

  map.createPane("radar");
  map.getPane("radar")!.style.zIndex = "350";
  map.getPane("radar")!.style.pointerEvents = "none";
  map.createPane("labels");
  map.getPane("labels")!.style.zIndex = "450";
  map.getPane("labels")!.style.pointerEvents = "none";

  const attribution =
    '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> · ' +
    '© <a href="https://carto.com/attributions">CARTO</a> · ' +
    'Weather data by <a href="https://www.rainviewer.com/">RainViewer</a>';

  L.tileLayer("https://{s}.basemaps.cartocdn.com/dark_nolabels/{z}/{x}/{y}{r}.png", {
    subdomains: "abcd",
    maxZoom: 19,
    detectRetina: true,
    attribution,
  }).addTo(map);
  L.tileLayer("https://{s}.basemaps.cartocdn.com/dark_only_labels/{z}/{x}/{y}{r}.png", {
    pane: "labels",
    subdomains: "abcd",
    maxZoom: 19,
    detectRetina: true,
  }).addTo(map);

  async function fetchJSON(url: string, ms = 4000): Promise<unknown> {
    const ctrl = new AbortController();
    const timer = setTimeout(() => ctrl.abort(), ms);
    try {
      const r = await fetch(url, { signal: ctrl.signal });
      if (!r.ok) throw new Error("not ok");
      return await r.json();
    } finally {
      clearTimeout(timer);
    }
  }

  async function locate(): Promise<GeoResult> {
    try {
      const d = (await fetchJSON("https://ipwho.is/")) as Record<string, unknown>;
      if (d.success !== false && d.latitude != null)
        return {
          lat: +(d.latitude as number),
          lon: +(d.longitude as number),
          label: [d.city, d.country].filter(Boolean).join(", "),
        };
    } catch {
      /* try next */
    }
    try {
      const d = (await fetchJSON("https://ipapi.co/json/")) as Record<string, unknown>;
      if (d.latitude != null)
        return {
          lat: +(d.latitude as number),
          lon: +(d.longitude as number),
          label: [d.city, d.country_name].filter(Boolean).join(", "),
        };
    } catch {
      /* use fallback */
    }
    return { lat: CFG.FALLBACK.lat, lon: CFG.FALLBACK.lon, label: CFG.FALLBACK.label };
  }

  const radarLayers: TimedLayer[] = [];

  async function loadRadar() {
    let data: Record<string, unknown>;
    try {
      data = (await fetchJSON(
        "https://api.rainviewer.com/public/weather-maps.json",
        6000
      )) as Record<string, unknown>;
    } catch {
      showNotice();
      return;
    }

    const host = data.host as string;
    const radarData = data.radar as Record<string, unknown> | undefined;
    const frames = (radarData?.past as Array<{ path: string; time: number }>) ?? [];
    if (!frames.length) {
      showNotice();
      return;
    }

    frames.forEach((f) => {
      const url = `${host}${f.path}/${CFG.TILE_SIZE}/{z}/{x}/{y}/${CFG.COLOR}/${CFG.OPTIONS}.png`;
      const layer = L.tileLayer(url, {
        pane: "radar",
        opacity: 0,
        tileSize: CFG.TILE_SIZE,
        maxNativeZoom: 7,
        maxZoom: 19,
      }) as TimedLayer;
      layer._time = f.time;
      layer.addTo(map);
      radarLayers.push(layer);
    });

    const n = radarLayers.length;
    const updateHud = (i: number) => {
      radarLayers.forEach((l, j) => l.setOpacity(j === i ? CFG.RADAR_OPACITY : 0));
      const pct = n > 1 ? (i / (n - 1)) * 100 : 100;
      $rh("rvFill").style.width = `${pct}%`;
      $rh("rvDot").style.left = `${pct}%`;
      $rh("rvClock").textContent = fmtTime(radarLayers[i]._time ?? 0);
      $rh("rvLive").classList.toggle("is-on", i === n - 1);
    };

    let idx = n - 1;
    updateHud(idx);

    if (prefersReduced || n < 2) return;

    const tick = () => {
      idx = (idx + 1) % n;
      updateHud(idx);
      setTimeout(tick, idx === n - 1 ? CFG.PAUSE_LAST_MS : CFG.FRAME_MS);
    };
    setTimeout(tick, 900);
  }

  loadRadar();
  const loc = await locate();
  map.setView([loc.lat, loc.lon], CFG.ZOOM, { animate: true });
  L.marker([loc.lat, loc.lon], {
    icon: L.divIcon({
      className: "rh-user-pin",
      html: '<span class="rh-user-pin__ring"></span><span class="rh-user-pin__core"></span>',
      iconSize: [9, 9],
    }),
    keyboard: false,
    interactive: false,
  }).addTo(map);
  $rh("rvPlace").textContent = loc.label || "—";
</script>
