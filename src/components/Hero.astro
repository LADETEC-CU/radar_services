---
// Hero.astro
const locale = Astro.currentLocale || 'en';
---
<section
  id="hero-section"
  class="relative min-h-screen flex items-center pt-16 overflow-hidden transition-colors duration-300"
>
  <!-- Background shader -->
  <div class="absolute inset-0 w-full h-full pointer-events-none z-0">
    <canvas id="shader-canvas-ANIMATION_2" class="block w-full h-full"></canvas>
  </div>

  <!-- Hero Content -->
  <div class="container mx-auto px-margin-mobile max-w-container-max z-10">
    <div class="max-w-3xl space-y-6">
      <div class="flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-primary-container animate-pulse"></span>
        <span class="font-technical-label text-[10px] uppercase tracking-widest text-primary-container">
          {locale === 'es' ? 'Estado del Sistema: Mando de Radar Soberano Activo' : 'System Status: Sovereign Radar Command Active'}
        </span>
      </div>
      
      <h1 class="font-display-lg text-display-lg-mobile md:text-display-lg text-on-background leading-tight">
        {locale === 'es' ? (
          <>
            Ingeniería de Radares Soberana. <br />
            <span class="text-primary-container">40 Años de Innovación en Código Abierto.</span>
          </>
        ) : (
          <>
            Sovereign Radar Engineering. <br />
            <span class="text-primary-container">40 Years of Open-Source Innovation.</span>
          </>
        )}
      </h1>
      
      <p class="text-body-lg text-on-surface-variant max-w-xl">
        {locale === 'es' ? (
          <>Desde el <strong>corazón digital FPGA de 16 bits</strong> de <strong>LAMULA™ DRx-DSP</strong> hasta el mando remoto por IoT y la analítica avanzada <strong>ORPG</strong>. Diseñamos los ecosistemas de código abierto y alta precisión que le otorgan independencia total en la observación atmosférica.</>
        ) : (
          <>From the <strong>16-bit FPGA digital heart</strong> of the <strong>LAMULA™ DRx-DSP</strong> to IoT-enabled remote command and advanced <strong>ORPG</strong> analytics. We engineer the high-precision, open-source ecosystems that grant you total independence in atmospheric observation.</>
        )}
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 pt-4">
        <a
          href="#tech-focus"
          class="inline-block text-center bg-primary-container text-background font-technical-label px-8 py-4 glow-button uppercase tracking-wider font-bold transition-all duration-300"
        >
          {locale === 'es' ? 'Explorar Nuestra Tecnología' : 'Explore Our Technology'}
        </a>
        <a
          href="#contact"
          class="inline-block text-center border border-primary-container text-primary-container font-technical-label px-8 py-4 hover:bg-primary-container/10 transition-all uppercase tracking-wider"
        >
          {locale === 'es' ? 'Consultar a un Experto' : 'Consult an Expert'}
        </a>
      </div>
    </div>
  </div>

  <!-- Dynamic Coordinates Tracker Widget -->
  <div class="absolute bottom-12 right-margin-mobile hidden lg:block border-l border-primary-container/20 pl-6 py-2 z-10">
    <div class="font-technical-label text-[10px] text-outline uppercase tracking-tighter mb-1">
      {locale === 'es' ? 'Coordenadas Actuales' : 'Current Coordinates'}
    </div>
    <div id="coords-display" class="font-technical-label text-sm text-primary-container font-mono">
      40.7128° N, 74.0060° W
    </div>
  </div>
</section>

<script>
  const hero = document.getElementById('hero-section');
  const coordsDisplay = document.getElementById('coords-display');

  if (hero && coordsDisplay) {
    hero.addEventListener('mousemove', (e) => {
      const rect = hero.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;

      const width = rect.width;
      const height = rect.height;

      // Virtual lat/long calculations mapped to coordinates
      const lat = (4.7128 + (1 - y / height) * 36).toFixed(4);
      const lng = (-74.0060 - (x / width) * 40).toFixed(4);

      const latNum = parseFloat(lat);
      const lngNum = parseFloat(lng);

      const latDir = latNum >= 0 ? 'N' : 'S';
      const lngDir = lngNum >= 0 ? 'E' : 'W';

      coordsDisplay.textContent = `${Math.abs(latNum).toFixed(4)}° ${latDir}, ${Math.abs(lngNum).toFixed(4)}° ${lngDir}`;
    });

    // Reset coordinates to default when mouse leaves
    hero.addEventListener('mouseleave', () => {
      coordsDisplay.textContent = "40.7128° N, 74.0060° W";
    });
  }
</script>

<script>
  (function () {
    const canvas = document.getElementById('shader-canvas-ANIMATION_2') as HTMLCanvasElement;
    if (!canvas) return;

    function syncSize() {
      const w = canvas.clientWidth || 1280;
      const h = canvas.clientHeight || 720;
      if (canvas.width !== w || canvas.height !== h) {
        canvas.width = w;
        canvas.height = h;
      }
    }
    if (typeof ResizeObserver !== 'undefined') {
      new ResizeObserver(syncSize).observe(canvas);
    }
    syncSize();

    const gl = canvas.getContext('webgl') || canvas.getContext('experimental-webgl');
    if (!gl) return;
    const vs = `attribute vec2 a_position;
varying vec2 v_texCoord;
void main() {
  v_texCoord = a_position * 0.5 + 0.5;
  gl_Position = vec4(a_position, 0.0, 1.0);
}`;
    const fs = `precision highp float;
uniform float u_time;
uniform vec2 u_resolution;
uniform vec2 u_mouse;
varying vec2 v_texCoord;

// Simplex 2D noise
vec3 permute(vec3 x) { return mod(((x*34.0)+1.0)*x, 289.0); }
float snoise(vec2 v){
  const vec4 C = vec4(0.211324865405187, 0.366025403784439,
           -0.577350269189626, 0.024390243902439);
  vec2 i  = floor(v + dot(v, C.yy) );
  vec2 x0 = v -   i + dot(i, C.xx);
  vec2 i1;
  i1 = (x0.x > x0.y) ? vec2(1.0, 0.0) : vec2(0.0, 1.0);
  vec4 x12 = x0.xyxy + C.xxzz;
  x12.xy -= i1;
  i = mod(i, 289.0);
  vec3 p = permute( permute( i.y + vec3(0.0, i1.y, 1.0 ))
  + i.x + vec3(0.0, i1.x, 1.0 ));
  vec3 m = max(0.5 - vec3(dot(x0,x0), dot(x12.xy,x12.xy),
    dot(x12.zw,x12.zw)), 0.0);
  m = m*m ;
  m = m*m ;
  vec3 x = 2.0 * fract(p * C.www) - 1.0;
  vec3 h = abs(x) - 0.5;
  vec3 ox = floor(x + 0.5);
  vec3 a0 = x - ox;
  m *= 1.79284291400159 - 0.85373472095314 * ( a0*a0 + h*h );
  vec3 g;
  g.x  = a0.x  * x0.x  + h.x  * x0.y;
  g.yz = a0.yz * x12.xz + h.yz * x12.yw;
  return 130.0 * dot(m, g);
}

void main() {
    vec2 uv = v_texCoord;
    vec2 centered_uv = (v_texCoord * 2.0 - 1.0) * vec2(u_resolution.x/u_resolution.y, 1.0);
    
    // Radar sweep effect
    float angle = atan(centered_uv.y, centered_uv.x);
    float dist = length(centered_uv);
    float sweep = fract(angle / 6.28318 - u_time * 0.2);
    sweep = pow(sweep, 4.0);
    
    // Atmospheric noise
    float n = snoise(uv * 3.0 + u_time * 0.1);
    n += 0.5 * snoise(uv * 6.0 - u_time * 0.2);
    
    // Grid lines
    vec2 grid = fract(uv * 15.0);
    float gridLine = smoothstep(0.02, 0.0, grid.x) + smoothstep(0.02, 0.0, grid.y);
    gridLine *= 0.15;

    // Color Palette
    vec3 obsidian = vec3(0.043, 0.059, 0.098); // #0B0F19
    vec3 radarCyan = vec3(0.0, 0.95, 0.99);    // #00F2FE
    vec3 neonGreen = vec3(0.2, 1.0, 0.4);
    
    // Composition
    vec3 color = obsidian;
    
    // Add atmospheric volume (storm cells)
    float cell = smoothstep(0.4, 0.8, n);
    color = mix(color, radarCyan * 0.4, cell * (1.0 - dist * 0.5));
    color = mix(color, neonGreen * 0.3, cell * sweep);
    
    // Add radar sweep line
    color += radarCyan * sweep * smoothstep(0.8, 0.0, dist);
    
    // Add grid
    color += vec3(0.5, 0.7, 1.0) * gridLine;

    // Vignette
    color *= 1.0 - smoothstep(0.5, 1.5, dist);

    gl_FragColor = vec4(color, 1.0);
}`;
    function cs(type: number, src: string) {
      const s = gl.createShader(type);
      if (!s) return null;
      gl.shaderSource(s, src);
      gl.compileShader(s);
      return s;
    }
    const prog = gl.createProgram();
    const vsShader = cs(gl.VERTEX_SHADER, vs);
    const fsShader = cs(gl.FRAGMENT_SHADER, fs);
    if (!prog || !vsShader || !fsShader) return;
    gl.attachShader(prog, vsShader);
    gl.attachShader(prog, fsShader);
    gl.linkProgram(prog);
    gl.useProgram(prog);
    const buf = gl.createBuffer();
    gl.bindBuffer(gl.ARRAY_BUFFER, buf);
    gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1, -1, 1, -1, -1, 1, 1, 1]), gl.STATIC_DRAW);
    const pos = gl.getAttribLocation(prog, 'a_position');
    gl.enableVertexAttribArray(pos);
    gl.vertexAttribPointer(pos, 2, gl.FLOAT, false, 0, 0);
    const uTime = gl.getUniformLocation(prog, 'u_time');
    const uRes = gl.getUniformLocation(prog, 'u_resolution');
    const uMouse = gl.getUniformLocation(prog, 'u_mouse');

    let mouse = { x: canvas.width / 2, y: canvas.height / 2 };
    window.addEventListener('mousemove', (event) => {
      const rect = canvas.getBoundingClientRect();
      if (rect.width && rect.height) {
        const nx = (event.clientX - rect.left) / rect.width;
        const ny = 1.0 - (event.clientY - rect.top) / rect.height;
        mouse.x = nx * canvas.width;
        mouse.y = ny * canvas.height;
      }
    });

    function render(t: number) {
      if (typeof ResizeObserver === 'undefined') syncSize();
      gl.viewport(0, 0, canvas.width, canvas.height);
      if (uTime) gl.uniform1f(uTime, t * 0.001);
      if (uRes) gl.uniform2f(uRes, canvas.width, canvas.height);
      if (uMouse) gl.uniform2f(uMouse, mouse.x, mouse.y);
      gl.drawArrays(gl.TRIANGLE_STRIP, 0, 4);
      requestAnimationFrame(render);
    }
    render(0);
  })();
</script>

