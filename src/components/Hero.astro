---
// Hero.astro
import { resolveLang, useTranslations } from "../i18n/utils";
import RadarShader from "./RadarShader.astro";

const lang = resolveLang(Astro.currentLocale);
const t = useTranslations(lang);
---

<section
  id="hero"
  class="relative flex min-h-screen items-center overflow-hidden pt-16 transition-colors duration-300"
>
  <!-- Background shader -->
  <RadarShader />

  <!-- Hero Content -->
  <div class="z-10 container mx-auto max-w-container-max px-margin-mobile">
    <div class="max-w-3xl space-y-6">
      <h1
        class="font-display-lg text-display-lg-mobile leading-tight text-on-background md:text-display-lg"
      >
        {t("hero.title.lead")}
        <br />
        <span class="text-primary-container">{t("hero.title.accent")}</span>
      </h1>

      <p class="max-w-xl text-body-lg text-on-surface-variant" set:html={t("hero.lead")} />

      <div class="flex flex-col gap-4 pt-4 sm:flex-row">
        <a
          href="#tech-focus"
          class="glow-button inline-block bg-primary-container px-8 py-4 text-center font-technical-label font-bold tracking-wider text-background uppercase transition-all duration-300"
        >
          {t("hero.cta.primary")}
        </a>
        <a
          href="#contact"
          class="inline-block border border-primary-container px-8 py-4 text-center font-technical-label tracking-wider text-primary-container uppercase transition-all hover:bg-primary-container/10"
        >
          {t("hero.cta.secondary")}
        </a>
      </div>
    </div>
  </div>

  <!-- Dynamic Coordinates Tracker Widget -->
  <div
    class="absolute right-margin-mobile bottom-12 z-10 hidden border-l border-primary-container/20 py-2 pl-6 lg:block"
  >
    <div class="mb-1 font-technical-label text-[10px] tracking-tighter text-outline uppercase">
      {t("hero.coords")}
    </div>
    <div id="coords-display" class="font-mono font-technical-label text-sm text-primary-container">
      40.7128° N, 74.0060° W
    </div>
  </div>
</section>

<script>
  const hero = document.getElementById("hero");
  const coordsDisplay = document.getElementById("coords-display");

  if (hero && coordsDisplay) {
    hero.addEventListener("mousemove", (e) => {
      const rect = hero.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;

      const width = rect.width;
      const height = rect.height;

      // Virtual lat/long calculations mapped to coordinates
      const lat = (4.7128 + (1 - y / height) * 36).toFixed(4);
      const lng = (-74.006 - (x / width) * 40).toFixed(4);

      const latNum = parseFloat(lat);
      const lngNum = parseFloat(lng);

      const latDir = latNum >= 0 ? "N" : "S";
      const lngDir = lngNum >= 0 ? "E" : "W";

      coordsDisplay.textContent = `${Math.abs(latNum).toFixed(4)}° ${latDir}, ${Math.abs(lngNum).toFixed(4)}° ${lngDir}`;
    });

    // Reset coordinates to default when mouse leaves
    hero.addEventListener("mouseleave", () => {
      coordsDisplay.textContent = "40.7128° N, 74.0060° W";
    });
  }
</script>
