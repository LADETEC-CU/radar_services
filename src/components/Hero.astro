---
import { getRelativeLocaleUrl } from "astro:i18n";
import { resolveLang, useTranslations, otherLang, getRouteFromPathname } from "../i18n/utils";
import { localeCode } from "../i18n/ui";

const lang = resolveLang(Astro.currentLocale);
const t = useTranslations(lang);

const target = otherLang(lang);
const switchHref = getRelativeLocaleUrl(target, getRouteFromPathname(Astro.url.pathname, lang));
---

<style is:global>
  @import "leaflet/dist/leaflet.css";

  /* ---- Radar hero: always-dark, theme-isolated, split layout ---- */
  .radar-hero {
    /* Map/HUD palette (unchanged from the previous iteration). */
    --rh-bg: #070b10;
    --rh-text: #e7ecf2;
    --rh-muted: #8a97a6;
    --rh-line: rgba(255, 255, 255, 0.12);
    --rh-panel: rgba(9, 13, 19, 0.55);
    --rh-signal: #35e0c4;

    /* Copy-column palette (design brief tokens). */
    --lh-bg: #0a1216;
    --lh-panel: #0e171c;
    --lh-line: #1d2b32;
    --lh-text: #ebf1f3;
    --lh-muted: #8fa3ab;
    --lh-teal: #2fe6c3;
    --lh-teal-dim: rgba(47, 230, 195, 0.14);

    display: grid;
    grid-template-columns: minmax(400px, 500px) 1fr;
    height: 100vh;
    height: 100dvh;
  }

  /* ---- Copy column ---- */
  .rh-copy {
    position: relative;
    padding: clamp(2rem, 5vw, 4rem) clamp(1.5rem, 4vw, 3.25rem);
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow-y: auto;
    border-right: 1px solid var(--lh-line);
    color: var(--lh-text);
  }

  .rh-copy-brand {
    position: absolute;
    top: clamp(1.5rem, 3vw, 2.25rem);
    left: clamp(1.5rem, 4vw, 3.25rem);
    display: flex;
    align-items: center;
    gap: 0.65rem;
    font-family: "IBM Plex Mono", ui-monospace, monospace;
    font-weight: 600;
    letter-spacing: 0.1em;
    font-size: 0.85rem;
    color: var(--lh-text);
    text-decoration: none;
  }
  .rh-copy-brand img {
    display: block;
  }

  .rh-copy-content {
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
  }

  .rh-eyebrow {
    font-family: "IBM Plex Mono", ui-monospace, monospace;
    font-size: 0.75rem;
    letter-spacing: 0.14em;
    color: var(--lh-teal);
    text-transform: uppercase;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .rh-eyebrow::before {
    content: "";
    width: 26px;
    height: 1px;
    background: var(--lh-teal);
  }

  .rh-title {
    font-family: "Archivo", sans-serif;
    font-variation-settings:
      "wdth" 100,
      "wght" 500;
    font-size: clamp(2.4rem, 4.3vw, 3.7rem);
    line-height: 1.02;
    letter-spacing: -0.015em;
    text-wrap: balance;
    margin: 0;
  }
  .rh-title .rh-accent {
    color: var(--lh-teal);
    font-size: xx-large;
  }

  .rh-lede {
    color: var(--lh-muted);
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-size: 1.05rem;
    line-height: 1.65;
    max-width: 42ch;
    margin: 0;
  }
  .rh-lede strong {
    color: var(--lh-text);
    font-weight: 600;
  }

  .rh-specs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .rh-chip {
    font-family: "IBM Plex Mono", ui-monospace, monospace;
    font-size: 0.72rem;
    letter-spacing: 0.03em;
    color: var(--lh-muted);
    border: 1px solid var(--lh-line);
    border-radius: 4px;
    padding: 0.42rem 0.65rem;
  }
  .rh-chip strong {
    color: var(--lh-text);
    font-weight: 500;
  }

  .rh-actions {
    display: flex;
    gap: 0.7rem;
    flex-wrap: nowrap;
  }
  .rh-cta-primary,
  .rh-cta-secondary {
    display: inline-block;
    flex: 1 1 0;
    min-width: 0;
    font-family: "IBM Plex Mono", ui-monospace, monospace;
    font-size: clamp(0.68rem, 1.6vw, 0.82rem);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
    text-align: center;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    padding: 1rem 1rem;
    border-radius: 5px;
    transition:
      transform 0.12s,
      background 0.15s,
      border-color 0.15s,
      box-shadow 0.25s;
  }
  .rh-cta-primary {
    background: var(--lh-teal);
    color: #06211b;
  }
  .rh-cta-primary:hover {
    background: #54edd0;
    transform: translateY(-1px);
  }
  .rh-cta-secondary {
    color: var(--lh-text);
    border: 1px solid var(--lh-line);
  }
  .rh-cta-secondary:hover {
    border-color: var(--lh-teal);
  }

  .rh-proof {
    display: flex;
    gap: 1rem;
    flex-wrap: nowrap;
    justify-content: space-between;
    margin-top: 0.4rem;
    padding-top: 1.4rem;
    border-top: 1px solid var(--lh-line);
  }
  .rh-proof div {
    min-width: 0;
    flex: 1 1 0;
  }
  .rh-proof div b {
    display: block;
    font-family: "Archivo", sans-serif;
    font-variation-settings:
      "wdth" 115,
      "wght" 700;
    font-size: 1.35rem;
    font-style: normal;
  }
  .rh-proof div span {
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-size: 0.76rem;
    color: var(--lh-muted);
    letter-spacing: 0.02em;
  }

  /* ---- Radar viewport column ---- */
  .rh-scope {
    position: relative;
    overflow: hidden;
    isolation: isolate;
  }

  .rh-scope #rh-map {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .rh-scope .leaflet-container {
    background: var(--rh-bg);
    font-family: "JetBrains Mono", ui-monospace, monospace;
  }
  .rh-scope .leaflet-control-attribution {
    background: rgba(7, 11, 16, 0.66) !important;
    color: var(--rh-muted) !important;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 10.5px;
    backdrop-filter: blur(4px);
  }
  .rh-scope .leaflet-control-attribution a {
    color: #b9c4d1 !important;
  }

  /* Controls (theme toggle + language switch), floating over the map */
  .rh-controls {
    position: absolute;
    top: 16px;
    right: 16px;
    z-index: 1001;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .rh-lang {
    font-family: "IBM Plex Mono", ui-monospace, monospace;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--lh-text);
    text-decoration: none;
    border: 1px solid var(--lh-line);
    background: rgba(10, 18, 22, 0.7);
    backdrop-filter: blur(6px);
    padding: 0.45rem 0.7rem;
    border-radius: 4px;
  }
  .rh-lang:hover {
    border-color: var(--lh-teal);
  }
  .rh-theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--lh-text);
    border: 1px solid var(--lh-line);
    background: rgba(10, 18, 22, 0.7);
    backdrop-filter: blur(6px);
    padding: 0.45rem;
    border-radius: 4px;
    cursor: pointer;
  }
  .rh-theme-toggle:hover {
    border-color: var(--lh-teal);
  }
  .rh-theme-toggle .material-symbols-outlined {
    font-size: 1.15rem;
  }

  /* HUD layers */
  .rh-hud {
    position: absolute;
    z-index: 1000;
    pointer-events: none;
  }
  .rh-hud--top {
    top: 0;
    left: 0;
    right: 0;
    padding: 22px calc(clamp(18px, 4vw, 44px) + 84px) 22px clamp(18px, 4vw, 44px);
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 18px;
  }
  .rh-hud--bottom {
    bottom: 0;
    left: 0;
    right: 0;
    padding: 0 clamp(18px, 4vw, 44px) 20px;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
  }

  /* Radar live indicator */
  .rh-brand {
    display: flex;
    align-items: center;
    gap: 9px;
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--rh-text);
    font-family: "Inter", ui-sans-serif, system-ui, sans-serif;
  }
  .rh-brand__name {
    color: var(--rh-muted);
  }
  .rh-live-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--rh-signal);
    box-shadow: 0 0 0 0 rgba(53, 224, 196, 0.7);
    animation: rh-pulse 2s ease-out infinite;
  }
  @keyframes rh-pulse {
    0% {
      box-shadow: 0 0 0 0 rgba(53, 224, 196, 0.55);
    }
    70% {
      box-shadow: 0 0 0 10px rgba(53, 224, 196, 0);
    }
    100% {
      box-shadow: 0 0 0 0 rgba(53, 224, 196, 0);
    }
  }

  .rh-place {
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 12.5px;
    color: var(--rh-muted);
    text-align: right;
  }
  .rh-place strong {
    color: var(--rh-text);
    font-weight: 500;
  }

  /* Intensity legend */
  .rh-legend {
    pointer-events: none;
  }
  .rh-legend__label {
    font-family: "JetBrains Mono", monospace;
    font-size: 10.5px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--rh-muted);
    margin-bottom: 7px;
  }
  .rh-legend__bar {
    height: 8px;
    width: min(220px, 42vw);
    border-radius: 999px;
    border: 1px solid var(--rh-line);
    background: linear-gradient(
      90deg,
      #0a2a5e 0%,
      #1f6fd0 22%,
      #25c39a 46%,
      #e4d33b 68%,
      #ec7a2a 84%,
      #d63b3b 100%
    );
  }
  .rh-legend__scale {
    display: flex;
    justify-content: space-between;
    margin-top: 6px;
    font-family: "JetBrains Mono", monospace;
    font-size: 10px;
    color: var(--rh-muted);
  }

  /* Timeline */
  .rh-timeline {
    pointer-events: none;
    min-width: min(360px, 90vw);
    flex: 1 1 300px;
    max-width: 520px;
  }
  .rh-timeline__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 8px;
  }
  .rh-timeline__scale {
    font-family: "JetBrains Mono", monospace;
    font-size: 10.5px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--rh-muted);
  }
  .rh-timeline__readout {
    font-family: "JetBrains Mono", monospace;
    font-size: 13px;
    color: var(--rh-text);
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .rh-live-tag {
    font-size: 9.5px;
    letter-spacing: 0.14em;
    padding: 2px 7px;
    border-radius: 999px;
    color: var(--rh-bg);
    background: var(--rh-signal);
    font-weight: 600;
    opacity: 0;
    transition: opacity 0.2s;
  }
  .rh-live-tag.is-on {
    opacity: 1;
  }
  .rh-timeline__track {
    position: relative;
    height: 3px;
    padding: 9px 0;
    margin: -9px 0;
    border-radius: 999px;
    background-clip: content-box;
    background: rgba(255, 255, 255, 0.14);
    pointer-events: all;
    cursor: pointer;
    touch-action: none;
  }
  .rh-timeline__fill {
    position: absolute;
    left: 0;
    top: 9px;
    height: 3px;
    width: 0%;
    border-radius: 999px;
    background: var(--rh-signal);
    transition: width 0.28s ease;
  }
  .rh-timeline__dot {
    position: absolute;
    top: 50%;
    left: 0%;
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: var(--rh-signal);
    transform: translate(-50%, -50%);
    transition: left 0.28s ease;
    box-shadow: 0 0 12px rgba(53, 224, 196, 0.7);
  }

  /* Playback controls */
  .rh-timeline__controls {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 10px;
    pointer-events: all;
  }
  .rh-speed-group {
    display: flex;
    gap: 4px;
  }
  .rh-control-btn {
    font-family: "JetBrains Mono", monospace;
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--rh-muted);
    background: transparent;
    border: 1px solid var(--rh-line);
    border-radius: 4px;
    padding: 4px 9px;
    cursor: pointer;
    transition:
      color 0.2s,
      border-color 0.2s,
      background 0.2s;
  }
  .rh-control-btn:hover {
    color: var(--rh-text);
    border-color: var(--rh-signal);
  }
  .rh-control-btn.is-active {
    color: var(--rh-bg);
    background: var(--rh-signal);
    border-color: var(--rh-signal);
  }

  .rh-icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6px;
    line-height: 0;
  }
  .rh-icon-btn svg {
    fill: currentColor;
    display: block;
  }
  .rh-icon-btn .rh-icon-play {
    display: none;
  }
  .rh-icon-btn[aria-pressed="true"] .rh-icon-pause {
    display: none;
  }
  .rh-icon-btn[aria-pressed="true"] .rh-icon-play {
    display: block;
  }

  /* User location marker */
  .rh-user-pin {
    position: relative;
  }
  .rh-user-pin__core {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 9px;
    height: 9px;
    margin: -4.5px 0 0 -4.5px;
    border-radius: 50%;
    background: var(--rh-signal);
    box-shadow:
      0 0 0 2px rgba(7, 11, 16, 0.9),
      0 0 14px rgba(53, 224, 196, 0.9);
  }
  .rh-user-pin__ring {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 9px;
    height: 9px;
    margin: -4.5px 0 0 -4.5px;
    border-radius: 50%;
    border: 1.5px solid var(--rh-signal);
    animation: rh-ping 2.4s ease-out infinite;
  }
  @keyframes rh-ping {
    0% {
      transform: scale(1);
      opacity: 0.8;
    }
    100% {
      transform: scale(4.2);
      opacity: 0;
    }
  }

  /* Status notice */
  .rh-notice {
    position: absolute;
    z-index: 1001;
    left: 50%;
    bottom: 96px;
    transform: translateX(-50%);
    pointer-events: none;
    padding: 8px 14px;
    border: 1px solid var(--rh-line);
    border-radius: 999px;
    background: var(--rh-panel);
    backdrop-filter: blur(8px);
    font-family: "JetBrains Mono", monospace;
    font-size: 12px;
    color: var(--rh-muted);
    opacity: 0;
    transition: opacity 0.3s;
    white-space: nowrap;
  }
  .rh-notice.is-on {
    opacity: 1;
  }

  /* ---- Responsive: single column below 900px ---- */
  @media (max-width: 900px) {
    .radar-hero {
      grid-template-columns: 1fr;
      height: auto;
      min-height: 0;
    }
    .rh-copy {
      border-right: none;
      border-bottom: 1px solid var(--lh-line);
      padding-top: 6rem;
      padding-bottom: 2.5rem;
    }
    .rh-scope {
      height: 70vh;
      min-height: 420px;
    }
    .rh-controls {
      position: fixed;
    }
  }

  @media (max-width: 640px) {
    .rh-place {
      display: none;
    }
    .rh-hud--top {
      padding-right: clamp(18px, 4vw, 44px);
    }
    .rh-hud--bottom {
      gap: 16px;
    }
    .rh-legend {
      order: 2;
    }
    .rh-timeline {
      order: 1;
      flex-basis: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .rh-live-dot,
    .rh-user-pin__ring {
      animation: none;
    }
    .rh-timeline__fill,
    .rh-timeline__dot {
      transition: none;
    }
  }

  /* Focus visibility for keyboard users */
  .rh-copy-brand:focus-visible,
  .rh-lang:focus-visible,
  .rh-theme-toggle:focus-visible,
  .rh-cta-primary:focus-visible,
  .rh-cta-secondary:focus-visible,
  .rh-timeline__track:focus-visible {
    outline: 2px solid var(--lh-teal);
    outline-offset: 3px;
    border-radius: 2px;
  }
</style>

<section id="hero" class="radar-hero" aria-labelledby="hero-title">
  <div class="rh-copy">
    <a class="rh-copy-brand" href="#hero" aria-label="LADETEC SYSTEMS">
      <img src="/logo.webp" alt="" width="24" height="24" />
      <span>LADETEC&nbsp;SYSTEMS</span>
    </a>

    <div class="rh-copy-content">
      <p class="rh-eyebrow">{t("hero.eyebrow")}</p>
      <h1 id="hero-title" class="rh-title">
        {t("hero.title.lead")}
        <span class="rh-accent">{t("hero.title.accent")}</span>
      </h1>
      <p class="rh-lede" set:html={t("hero.lead")} />

      <div class="rh-specs" aria-label={t("hero.specs.aria")}>
        <span class="rh-chip" set:html={t("hero.chip1")} />
        <span class="rh-chip" set:html={t("hero.chip2")} />
        <span class="rh-chip" set:html={t("hero.chip3")} />
      </div>

      <div class="rh-actions">
        <a href="#tech-focus" class="rh-cta-primary">{t("hero.cta.primary")}</a>
        <a href="#contact" class="rh-cta-secondary">{t("hero.cta.secondary")}</a>
      </div>

      <div class="rh-proof">
        <div><b>{t("hero.proof1.value")}</b><span>{t("hero.proof1.label")}</span></div>
        <div><b>{t("hero.proof2.value")}</b><span>{t("hero.proof2.label")}</span></div>
        <div><b>{t("hero.proof3.value")}</b><span>{t("hero.proof3.label")}</span></div>
      </div>
    </div>
  </div>

  <div class="rh-scope" aria-label={t("hero.radar.aria")}>
    <div class="rh-controls">
      <button
        id="hero-theme-toggle"
        class="js-theme-toggle rh-theme-toggle"
        aria-label="Toggle Theme"
      >
        <span class="material-symbols-outlined theme-icon-moon">dark_mode</span>
        <span class="material-symbols-outlined theme-icon-sun">light_mode</span>
      </button>

      <a
        id="lang-toggle"
        class="rh-lang"
        href={switchHref}
        hreflang={target}
        aria-label={t("nav.switchLabel")}
      >
        {localeCode[target]}
      </a>
    </div>

    <div id="rh-map" role="img" aria-label={t("hero.radar.mapAria")}></div>

    <!-- Top HUD: radar live status + resolved place name -->
    <div class="rh-hud rh-hud--top">
      <div class="rh-brand">
        <span class="rh-live-dot"></span>
        {t("hero.radar.live")} &middot; <span class="rh-brand__name">Radar</span>
      </div>
      <div class="rh-place">
        {t("hero.radar.over")}
        <strong id="rvPlace">{t("hero.radar.locating")}</strong>
      </div>
    </div>

    <!-- Bottom HUD: intensity legend + scrubbable timeline -->
    <div class="rh-hud rh-hud--bottom">
      <div class="rh-legend">
        <div class="rh-legend__label">{t("hero.radar.intensity")}</div>
        <div class="rh-legend__bar"></div>
        <div class="rh-legend__scale">
          <span>{t("hero.radar.light")}</span>
          <span>{t("hero.radar.heavy")}</span>
        </div>
      </div>

      <div class="rh-timeline">
        <div class="rh-timeline__head">
          <span class="rh-timeline__scale">{t("hero.radar.scale")}</span>
          <span class="rh-timeline__readout">
            <span id="rvClock">--:--</span>
            <span class="rh-live-tag" id="rvLive">{t("hero.radar.now")}</span>
          </span>
        </div>
        <div
          class="rh-timeline__track"
          id="rvTrack"
          role="slider"
          tabindex="0"
          aria-label={t("hero.radar.scale")}
          aria-valuemin="0"
          aria-valuenow="0"
        >
          <div class="rh-timeline__fill" id="rvFill"></div>
          <div class="rh-timeline__dot" id="rvDot"></div>
        </div>
        <div class="rh-timeline__controls" id="rvControls">
          <button
            type="button"
            class="rh-control-btn rh-icon-btn"
            id="rvPauseBtn"
            aria-pressed="false"
            aria-label={t("hero.radar.pause")}
            data-pause={t("hero.radar.pause")}
            data-play={t("hero.radar.play")}
          >
            <svg
              class="rh-icon-pause"
              viewBox="0 0 16 16"
              width="11"
              height="11"
              aria-hidden="true"
            >
              <rect x="3" y="2" width="3.4" height="12"></rect>
              <rect x="9.6" y="2" width="3.4" height="12"></rect>
            </svg>
            <svg class="rh-icon-play" viewBox="0 0 16 16" width="11" height="11" aria-hidden="true">
              <path d="M4 2l10 6-10 6z"></path>
            </svg>
          </button>
          <div
            class="rh-speed-group"
            id="rvSpeedGroup"
            role="group"
            aria-label={t("hero.radar.speed")}
          >
            <button type="button" class="rh-control-btn" data-speed="0.25">0.5×</button>
            <button type="button" class="rh-control-btn is-active" data-speed="0.5">1×</button>
            <button type="button" class="rh-control-btn" data-speed="1">2×</button>
          </div>
        </div>
      </div>
    </div>

    <div class="rh-notice" id="rvNotice" data-nodata={t("hero.radar.nodata")}></div>
  </div>
</section>

<script>
  import L from "leaflet";

  interface TimedLayer extends L.TileLayer {
    _time?: number;
  }

  interface GeoResult {
    lat: number;
    lon: number;
    label: string;
  }

  const CFG = {
    ZOOM: 7,
    RADAR_OPACITY: 0.82,
    FRAME_MS: 480,
    PAUSE_LAST_MS: 1500,
    TILE_SIZE: 256,
    COLOR: 2,
    OPTIONS: "1_1",
    FALLBACK: { lat: 39.83, lon: -98.58, label: "—" },
  };

  const $rh = (id: string) => document.getElementById(id) as HTMLElement;
  const pad = (n: number) => String(n).padStart(2, "0");
  const fmtTime = (unix: number) => {
    const d = new Date(unix * 1000);
    return `${pad(d.getHours())}:${pad(d.getMinutes())}`;
  };
  const prefersReduced = window.matchMedia("(prefers-reduced-motion:reduce)").matches;

  function showNotice() {
    const n = $rh("rvNotice") as HTMLDivElement;
    n.textContent = n.dataset.nodata ?? "";
    n.classList.add("is-on");
  }

  const map = L.map("rh-map", {
    zoomControl: false,
    attributionControl: true,
    scrollWheelZoom: false,
    center: [CFG.FALLBACK.lat, CFG.FALLBACK.lon],
    zoom: CFG.ZOOM,
  });
  map.attributionControl.setPrefix(false);

  map.createPane("radar");
  map.getPane("radar")!.style.zIndex = "350";
  map.getPane("radar")!.style.pointerEvents = "none";
  map.createPane("labels");
  map.getPane("labels")!.style.zIndex = "450";
  map.getPane("labels")!.style.pointerEvents = "none";

  const attribution =
    '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> · ' +
    '© <a href="https://carto.com/attributions">CARTO</a> · ' +
    'Weather data by <a href="https://www.rainviewer.com/">RainViewer</a>';

  L.tileLayer("https://{s}.basemaps.cartocdn.com/dark_nolabels/{z}/{x}/{y}{r}.png", {
    subdomains: "abcd",
    maxZoom: 19,
    detectRetina: true,
    attribution,
  }).addTo(map);
  L.tileLayer("https://{s}.basemaps.cartocdn.com/dark_only_labels/{z}/{x}/{y}{r}.png", {
    pane: "labels",
    subdomains: "abcd",
    maxZoom: 19,
    detectRetina: true,
  }).addTo(map);

  async function fetchJSON(url: string, ms = 4000): Promise<unknown> {
    const ctrl = new AbortController();
    const timer = setTimeout(() => ctrl.abort(), ms);
    try {
      const r = await fetch(url, { signal: ctrl.signal });
      if (!r.ok) throw new Error("not ok");
      return await r.json();
    } finally {
      clearTimeout(timer);
    }
  }

  async function locate(): Promise<GeoResult> {
    try {
      const d = (await fetchJSON("https://ipwho.is/")) as Record<string, unknown>;
      if (d.success !== false && d.latitude != null)
        return {
          lat: +(d.latitude as number),
          lon: +(d.longitude as number),
          label: [d.city, d.country].filter(Boolean).join(", "),
        };
    } catch {
      /* try next */
    }
    try {
      const d = (await fetchJSON("https://ipapi.co/json/")) as Record<string, unknown>;
      if (d.latitude != null)
        return {
          lat: +(d.latitude as number),
          lon: +(d.longitude as number),
          label: [d.city, d.country_name].filter(Boolean).join(", "),
        };
    } catch {
      /* use fallback */
    }
    return { lat: CFG.FALLBACK.lat, lon: CFG.FALLBACK.lon, label: CFG.FALLBACK.label };
  }

  const radarLayers: TimedLayer[] = [];

  async function loadRadar() {
    let data: Record<string, unknown>;
    try {
      data = (await fetchJSON(
        "https://api.rainviewer.com/public/weather-maps.json",
        6000
      )) as Record<string, unknown>;
    } catch {
      showNotice();
      return;
    }

    const host = data.host as string;
    const radarData = data.radar as Record<string, unknown> | undefined;
    const frames = (radarData?.past as Array<{ path: string; time: number }>) ?? [];
    if (!frames.length) {
      showNotice();
      return;
    }

    frames.forEach((f) => {
      const url = `${host}${f.path}/${CFG.TILE_SIZE}/{z}/{x}/{y}/${CFG.COLOR}/${CFG.OPTIONS}.png`;
      const layer = L.tileLayer(url, {
        pane: "radar",
        opacity: 0,
        tileSize: CFG.TILE_SIZE,
        maxNativeZoom: 7,
        maxZoom: 19,
      }) as TimedLayer;
      layer._time = f.time;
      layer.addTo(map);
      radarLayers.push(layer);
    });

    const n = radarLayers.length;
    const track = $rh("rvTrack") as HTMLDivElement;
    track.setAttribute("aria-valuemax", String(n - 1));

    const updateHud = (i: number) => {
      radarLayers.forEach((l, j) => l.setOpacity(j === i ? CFG.RADAR_OPACITY : 0));
      const pct = n > 1 ? (i / (n - 1)) * 100 : 100;
      $rh("rvFill").style.width = `${pct}%`;
      $rh("rvDot").style.left = `${pct}%`;
      $rh("rvClock").textContent = fmtTime(radarLayers[i]._time ?? 0);
      $rh("rvLive").classList.toggle("is-on", i === n - 1);
      track.setAttribute("aria-valuenow", String(i));
    };

    let idx = n - 1;
    updateHud(idx);

    const controls = $rh("rvControls");
    if (prefersReduced || n < 2) {
      controls.style.display = "none";
      return;
    }

    let paused = false;
    let speed = 0.5;
    let timer: number | undefined;

    const nextDelay = () => (idx === n - 1 ? CFG.PAUSE_LAST_MS : CFG.FRAME_MS) / speed;

    const scheduleTick = (delay: number) => {
      window.clearTimeout(timer);
      timer = window.setTimeout(tick, delay);
    };

    const tick = () => {
      if (paused) return;
      idx = (idx + 1) % n;
      updateHud(idx);
      scheduleTick(nextDelay());
    };

    scheduleTick(900);

    const pauseBtn = $rh("rvPauseBtn") as HTMLButtonElement;
    pauseBtn.addEventListener("click", () => {
      paused = !paused;
      pauseBtn.classList.toggle("is-active", paused);
      pauseBtn.setAttribute("aria-pressed", String(paused));
      pauseBtn.setAttribute(
        "aria-label",
        paused ? pauseBtn.dataset.play! : pauseBtn.dataset.pause!
      );
      if (paused) window.clearTimeout(timer);
      else scheduleTick(nextDelay());
    });

    const speedBtns = document.querySelectorAll<HTMLButtonElement>("#rvSpeedGroup [data-speed]");
    speedBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        speed = Number(btn.dataset.speed);
        speedBtns.forEach((b) => b.classList.toggle("is-active", b === btn));
        if (!paused) scheduleTick(nextDelay());
      });
    });

    // Scrub: drag/click/keyboard to seek through the timeline
    let scrubbing = false;
    const seekToClientX = (clientX: number) => {
      const rect = track.getBoundingClientRect();
      const pct = Math.min(1, Math.max(0, (clientX - rect.left) / rect.width));
      idx = Math.round(pct * (n - 1));
      updateHud(idx);
    };
    const seekBy = (delta: number) => {
      idx = Math.min(n - 1, Math.max(0, idx + delta));
      updateHud(idx);
    };

    track.addEventListener("pointerdown", (e) => {
      scrubbing = true;
      track.setPointerCapture(e.pointerId);
      window.clearTimeout(timer);
      seekToClientX(e.clientX);
    });
    track.addEventListener("pointermove", (e) => {
      if (scrubbing) seekToClientX(e.clientX);
    });
    const endScrub = () => {
      if (!scrubbing) return;
      scrubbing = false;
      if (!paused) scheduleTick(nextDelay());
    };
    track.addEventListener("pointerup", endScrub);
    track.addEventListener("pointercancel", endScrub);
    track.addEventListener("keydown", (e) => {
      if (e.key !== "ArrowLeft" && e.key !== "ArrowRight") return;
      e.preventDefault();
      window.clearTimeout(timer);
      seekBy(e.key === "ArrowRight" ? 1 : -1);
      if (!paused) scheduleTick(nextDelay());
    });
  }

  loadRadar();
  const loc = await locate();
  map.setView([loc.lat, loc.lon], CFG.ZOOM, { animate: true });
  L.marker([loc.lat, loc.lon], {
    icon: L.divIcon({
      className: "rh-user-pin",
      html: '<span class="rh-user-pin__ring"></span><span class="rh-user-pin__core"></span>',
      iconSize: [9, 9],
    }),
    keyboard: false,
    interactive: false,
  }).addTo(map);
  $rh("rvPlace").textContent = loc.label || "—";

  // Language switcher: keep it pointed at the section currently in view, so
  // switching locale lands you in the same place instead of scrolling to top.
  const langToggle = document.getElementById("lang-toggle");
  if (langToggle) {
    const baseHref = langToggle.getAttribute("href") ?? "";
    const anchorIds = new Set(
      [...document.querySelectorAll('a[href^="#"]')].map((a) =>
        (a.getAttribute("href") ?? "").slice(1)
      )
    );
    const visible = new Map<string, number>();
    const apply = () => {
      let activeId = "";
      let best = 0;
      for (const [id, ratio] of visible) {
        if (ratio > best) {
          best = ratio;
          activeId = id;
        }
      }
      langToggle.setAttribute("href", baseHref + (activeId ? "#" + activeId : ""));
    };
    const spy = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) visible.set(e.target.id, e.intersectionRatio);
          else visible.delete(e.target.id);
        }
        apply();
      },
      { threshold: [0, 0.25, 0.5, 0.75, 1] }
    );
    document.querySelectorAll("main [id]").forEach((el) => {
      if (anchorIds.has(el.id)) spy.observe(el);
    });
    const footerEl = document.querySelector("footer[id]");
    if (footerEl) spy.observe(footerEl);
  }
</script>
