---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const lang = (Astro.currentLocale || 'en') as 'en' | 'es';

const defaultTitles = {
  en: "LADETEC | Atmospheric Precision Engineering",
  es: "LADETEC | Ingeniería de Precisión Atmosférica"
};

const defaultDescriptions = {
  en: "Next-Gen Weather Radar Engineering. Decades of Proven Expertise in atmospheric and environmental monitoring radar systems.",
  es: "Ingeniería de radares meteorológicos soberana. Décadas de experiencia comprobada en sistemas de monitoreo de radares atmosféricos y ambientales."
};

const { 
  title = defaultTitles[lang],
  description = defaultDescriptions[lang]
} = Astro.props;
---

<!DOCTYPE html>
<html lang={lang} class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    
    <!-- Fonts and Icons -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap"
      rel="stylesheet"
    />

    <!-- Theme Flash Prevention -->
    <script is:inline>
      (function() {
        const theme = localStorage.getItem('theme') || 'dark';
        if (theme === 'dark') {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      })();
    </script>
  </head>
  <body class="bg-background text-on-background font-body-lg overflow-x-hidden selection:bg-primary-container/30 transition-colors duration-300">
    <!-- Technical Grid Overlay -->
    <div class="fixed inset-0 technical-grid pointer-events-none z-0"></div>
    
    <!-- Main Content Slot -->
    <slot />
  </body>
</html>
