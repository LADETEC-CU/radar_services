{
  "name": "mechanical-matter",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "optimize:images": "python3 scripts/optimize_images.py",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "astro check",
    "verify:links": "linkinator ./dist --config .linkinatorrc.json",
    "verify:links:full": "linkinator ./dist --config .linkinatorrc.full.json",
    "verify": "pnpm lint && pnpm format:check && pnpm check && pnpm build && pnpm verify:links",
    "verify:full": "pnpm lint && pnpm format:check && pnpm check && pnpm build && pnpm verify:links:full"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@tailwindcss/vite": "^4.3.1",
    "astro": "^6.4.6",
    "swiper": "^12.2.0",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "eslint-plugin-astro": "^2.1.1",
    "globals": "^17.7.0",
    "linkinator": "^7.6.1",
    "prettier": "^3.8.5",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  }
}
